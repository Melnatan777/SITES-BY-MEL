<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — Admin</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="admin-wrap">
  <%- include('../partials/admin-nav', { activePage: 'dashboard' }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <h1>Dashboard</h1>
      <form action="/admin/logout" method="POST" style="margin:0;">
        <button class="btn btn-outline btn-sm">Sign Out</button>
      </form>
    </div>
    <div class="admin-content">

      <!-- STATS -->
      <div class="admin-cards">
        <div class="stat-card">
          <div class="stat-label">Total Revenue</div>
          <div class="stat-value">$<%= ((stats.revenue || 0) / 100).toFixed(0) %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Template Sales</div>
          <div class="stat-value"><%= stats.orders || 0 %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Setup Deposits</div>
          <div class="stat-value"><%= stats.setups || 0 %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">New Quotes</div>
          <div class="stat-value"><%= stats.quotes || 0 %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Unread Messages</div>
          <div class="stat-value"><%= stats.messages || 0 %></div>
        </div>
      </div>

      <!-- RECENT ORDERS -->
      <div class="admin-table-wrap">
        <div class="admin-table-header">
          <h2>Recent Template Orders</h2>
          <a href="/admin/orders" class="btn btn-outline btn-sm">View All</a>
        </div>
        <% if (recent_orders.length === 0) { %>
          <p style="padding:24px;color:var(--gray);font-size:0.9rem;">No orders yet.</p>
        <% } else { %>
        <table>
          <thead>
            <tr><th>Date</th><th>Product</th><th>Customer</th><th>Amount</th><th>Status</th></tr>
          </thead>
          <tbody>
            <% recent_orders.forEach(function(o) { %>
            <tr>
              <td style="color:var(--gray);font-size:0.82rem;"><%= o.created_at ? o.created_at.substring(0,10) : '—' %></td>
              <td><%= o.product_name %></td>
              <td><%= o.customer_email || '—' %></td>
              <td>$<%= ((o.amount || 0) / 100).toFixed(2) %></td>
              <td><span class="badge <%= o.status === 'paid' ? 'badge-green' : o.status === 'refunded' ? 'badge-red' : 'badge-yellow' %>"><%= o.status %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>

      <!-- RECENT QUOTES -->
      <div class="admin-table-wrap">
        <div class="admin-table-header">
          <h2>Recent Quote Requests</h2>
          <a href="/admin/quotes" class="btn btn-outline btn-sm">View All</a>
        </div>
        <% if (recent_quotes.length === 0) { %>
          <p style="padding:24px;color:var(--gray);font-size:0.9rem;">No quote requests yet.</p>
        <% } else { %>
        <table>
          <thead>
            <tr><th>Date</th><th>Name</th><th>Business</th><th>Type</th><th>Status</th></tr>
          </thead>
          <tbody>
            <% recent_quotes.forEach(function(q) { %>
            <tr>
              <td style="color:var(--gray);font-size:0.82rem;"><%= q.created_at ? q.created_at.substring(0,10) : '—' %></td>
              <td><%= q.name %></td>
              <td><%= q.business_name || '—' %></td>
              <td style="font-size:0.82rem;color:var(--gray);"><%= q.project_type || '—' %></td>
              <td><span class="badge <%= q.status === 'new' ? 'badge-blue' : q.status === 'won' ? 'badge-green' : 'badge-gray' %>"><%= q.status %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>

    </div>
  </div>
</div>
</body>
</html>
