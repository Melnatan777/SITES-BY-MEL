<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — Sites by Mel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;background:#F4F2EE;color:#1B2F4E;min-height:100vh;display:flex}

    /* SIDEBAR */
    .sidebar{width:240px;background:#1B2F4E;min-height:100vh;flex-shrink:0;position:fixed;top:0;left:0;z-index:100;display:flex;flex-direction:column}
    .sb-logo{padding:26px 22px;border-bottom:1px solid rgba(255,255,255,.1)}
    .sb-logo-text{font-family:'Playfair Display',serif;font-size:1.1rem;color:white}
    .sb-logo-text span{color:#C9922B}
    .sb-logo-sub{font-size:.72rem;color:rgba(255,255,255,.4);margin-top:3px;letter-spacing:.5px;text-transform:uppercase}
    .sb-nav{flex:1;padding:12px 0;overflow-y:auto}
    .sb-section{padding:14px 22px 4px;font-size:.68rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.3)}
    .sb-nav a{display:flex;align-items:center;gap:10px;padding:10px 22px;color:rgba(255,255,255,.7);font-size:.875rem;font-weight:500;text-decoration:none;border-left:3px solid transparent;transition:all .15s}
    .sb-nav a:hover{background:rgba(255,255,255,.06);color:white}
    .sb-nav a.active{background:rgba(201,146,43,.15);color:#E8B04A;border-left-color:#C9922B}
    .sb-nav a .icon{font-size:.95rem;width:18px;text-align:center}
    .sb-badge{margin-left:auto;background:#C9922B;color:white;font-size:.68rem;font-weight:700;padding:2px 7px;border-radius:100px}
    .sb-badge.red{background:#c0392b}
    .sb-footer{padding:18px 22px;border-top:1px solid rgba(255,255,255,.1)}

    /* MAIN */
    .main{flex:1;margin-left:240px;min-height:100vh;display:flex;flex-direction:column}
    .topbar{background:white;padding:16px 32px;border-bottom:1px solid #E5E0D8;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;box-shadow:0 1px 4px rgba(0,0,0,.05)}
    .topbar-left h1{font-size:1.15rem;font-weight:700;color:#1B2F4E}
    .topbar-left .date{font-size:.8rem;color:#6B7280;margin-top:2px}
    .topbar-right{display:flex;align-items:center;gap:10px}
    .content{padding:28px 32px;flex:1}

    /* BUTTONS */
    .btn{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:6px;font-size:.85rem;font-weight:600;cursor:pointer;border:none;text-decoration:none;transition:all .15s;white-space:nowrap}
    .btn-gold{background:#C9922B;color:white}.btn-gold:hover{background:#b07d22;color:white}
    .btn-navy{background:#1B2F4E;color:white}.btn-navy:hover{background:#122240;color:white}
    .btn-ghost{background:#F4F2EE;color:#1B2F4E;border:1.5px solid #E5E0D8}.btn-ghost:hover{border-color:#1B2F4E}
    .btn-sm{padding:6px 13px;font-size:.78rem;border-radius:5px}

    /* ALERTS */
    .alerts{display:flex;flex-direction:column;gap:10px;margin-bottom:24px}
    .alert{display:flex;align-items:center;gap:12px;padding:12px 18px;border-radius:8px;font-size:.875rem;font-weight:500}
    .alert-red{background:#fdf0ed;border:1px solid #e8b4aa;color:#922b21}
    .alert-gold{background:#fdf6e3;border:1px solid #e8d5a3;color:#7d5a00}
    .alert a{color:inherit;font-weight:700;text-decoration:underline}

    /* STATS */
    .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px}
    .stat{background:white;border-radius:10px;padding:20px 22px;box-shadow:0 1px 6px rgba(0,0,0,.06);border-top:3px solid #1B2F4E}
    .stat.gold{border-top-color:#C9922B}
    .stat.green{border-top-color:#1a7a3c}
    .stat.red{border-top-color:#c0392b}
    .stat-label{font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:#6B7280;margin-bottom:8px}
    .stat-value{font-size:1.8rem;font-weight:800;color:#1B2F4E;line-height:1}
    .stat-sub{font-size:.75rem;color:#6B7280;margin-top:5px}

    /* GRIDS */
    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:22px;margin-bottom:22px}
    .grid-3{display:grid;grid-template-columns:2fr 1fr;gap:22px;margin-bottom:22px}
    .card{background:white;border-radius:10px;box-shadow:0 1px 6px rgba(0,0,0,.06);overflow:hidden}
    .card-head{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid #F4F2EE}
    .card-head h2{font-size:.95rem;font-weight:700;color:#1B2F4E}

    /* SETUP ITEMS */
    .setup-item{display:flex;align-items:flex-start;gap:14px;padding:14px 20px;border-bottom:1px solid #F4F2EE}
    .setup-item:last-child{border-bottom:none}
    .setup-avatar{width:38px;height:38px;border-radius:50%;background:#1B2F4E;color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;flex-shrink:0}
    .setup-info{flex:1;min-width:0}
    .setup-name{font-weight:600;font-size:.9rem;margin-bottom:2px}
    .setup-meta{font-size:.78rem;color:#6B7280}

    /* PIPELINE */
    .pipeline-item{display:flex;align-items:center;gap:12px;padding:13px 20px;border-bottom:1px solid #F4F2EE}
    .pipeline-item:last-child{border-bottom:none}
    .pipeline-info{flex:1;min-width:0}
    .pipeline-name{font-weight:600;font-size:.875rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .pipeline-meta{font-size:.75rem;color:#6B7280;margin-top:2px}

    /* ORDERS */
    .order-row{display:flex;align-items:center;padding:12px 20px;border-bottom:1px solid #F4F2EE;gap:12px}
    .order-row:last-child{border-bottom:none}
    .order-product{flex:1;font-size:.875rem;font-weight:600}
    .order-email{flex:1;font-size:.78rem;color:#6B7280;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .order-amount{font-weight:700;font-size:.875rem;color:#1a7a3c;white-space:nowrap}
    .order-date{font-size:.75rem;color:#9CA3AF;white-space:nowrap}

    /* MESSAGES */
    .msg-item{padding:13px 20px;border-bottom:1px solid #F4F2EE}
    .msg-item:last-child{border-bottom:none}
    .msg-sender{font-weight:600;font-size:.875rem}
    .msg-preview{font-size:.8rem;color:#6B7280;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .msg-date{font-size:.72rem;color:#9CA3AF;margin-top:3px}

    /* BADGES */
    .badge{display:inline-block;padding:3px 9px;border-radius:100px;font-size:.7rem;font-weight:700}
    .badge-green{background:#e6f4ec;color:#1a7a3c}
    .badge-gold{background:#fdf6e3;color:#7d5a00}
    .badge-red{background:#fdf0ed;color:#922b21}
    .badge-blue{background:#e8f0fe;color:#1a56a8}
    .badge-gray{background:#F4F2EE;color:#6B7280}

    /* EMPTY */
    .empty{text-align:center;padding:36px 20px;color:#9CA3AF;font-size:.875rem}
    .empty .ei{font-size:2rem;margin-bottom:8px}

    /* QUICK ACTIONS */
    .quick-actions{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px}

    /* MOBILE NAV */
    .mobile-nav{display:none;position:fixed;bottom:0;left:0;right:0;background:#1B2F4E;z-index:200;padding:6px 0 env(safe-area-inset-bottom,6px);border-top:1px solid rgba(255,255,255,.1)}
    .mobile-nav-inner{display:flex;justify-content:space-around}
    .mobile-nav a{display:flex;flex-direction:column;align-items:center;gap:2px;color:rgba(255,255,255,.6);text-decoration:none;font-size:.58rem;font-weight:600;padding:6px 8px;min-width:50px;text-align:center;position:relative}
    .mobile-nav a .mi{font-size:1.25rem;line-height:1}
    .mobile-nav a.active,.mobile-nav a:hover{color:#E8B04A}
    .m-dot{position:absolute;top:2px;right:6px;width:8px;height:8px;background:#c0392b;border-radius:50%}

    @media(max-width:900px){
      .sidebar{display:none}
      .main{margin-left:0;padding-bottom:72px}
      .topbar{padding:12px 16px}
      .content{padding:16px}
      .stats{grid-template-columns:1fr 1fr}
      .grid-2,.grid-3{grid-template-columns:1fr}
      .mobile-nav{display:block}
      .order-email{display:none}
    }
  </style>
</head>
<body>

<div class="sidebar">
  <div class="sb-logo">
    <div class="sb-logo-text">Sites by <span>Mel</span></div>
    <div class="sb-logo-sub">Admin Dashboard</div>
  </div>
  <nav class="sb-nav">
    <div class="sb-section">Overview</div>
    <a href="/admin" class="active"><span class="icon">📊</span> Dashboard</a>

    <div class="sb-section">Business</div>
    <a href="/admin/quotes">
      <span class="icon">💬</span> Quote Requests
      <% if(stats.new_quotes > 0){ %><span class="sb-badge red"><%= stats.new_quotes %></span><% } %>
    </a>
    <a href="/admin/setups">
      <span class="icon">🛠️</span> Active Setups
      <% if(stats.active_setups > 0){ %><span class="sb-badge"><%= stats.active_setups %></span><% } %>
    </a>
    <a href="/admin/orders"><span class="icon">🛒</span> Template Orders</a>
    <a href="/admin/messages">
      <span class="icon">✉️</span> Messages
      <% if(stats.unread_messages > 0){ %><span class="sb-badge red"><%= stats.unread_messages %></span><% } %>
    </a>

    <div class="sb-section">Catalog</div>
    <a href="/admin/products"><span class="icon">🗂️</span> Templates</a>

    <div class="sb-section">Reference</div>
    <a href="/admin/pricing"><span class="icon">💲</span> Pricing & Services</a>
    <a href="/admin/sop"><span class="icon">📋</span> Build Checklists</a>

    <div class="sb-section">Site</div>
    <a href="/" target="_blank"><span class="icon">🌐</span> View Live Site</a>
  </nav>
  <div class="sb-footer">
    <form action="/admin/logout" method="POST" style="margin:0">
      <button style="background:none;border:none;cursor:pointer;color:rgba(255,255,255,.45);font-size:.82rem;display:flex;align-items:center;gap:8px;font-family:inherit;padding:0" type="submit">🚪 Sign Out</button>
    </form>
  </div>
</div>

<div class="mobile-nav">
  <div class="mobile-nav-inner">
    <a href="/admin" class="active"><span class="mi">📊</span>Home</a>
    <a href="/admin/quotes">
      <span class="mi">💬</span>Quotes
      <% if(stats.new_quotes>0){ %><span class="m-dot"></span><% } %>
    </a>
    <a href="/admin/setups"><span class="mi">🛠️</span>Setups</a>
    <a href="/admin/orders"><span class="mi">🛒</span>Orders</a>
    <a href="/admin/messages">
      <span class="mi">✉️</span>Msgs
      <% if(stats.unread_messages>0){ %><span class="m-dot"></span><% } %>
    </a>
  </div>
</div>

<div class="main">
  <div class="topbar">
    <div class="topbar-left">
      <h1>Good <%= (new Date().getHours() < 12 ? 'morning' : new Date().getHours() < 17 ? 'afternoon' : 'evening') %>, Mel 👋</h1>
      <div class="date"><%= new Date().toLocaleDateString('en-US', {weekday:'long', month:'long', day:'numeric', year:'numeric'}) %></div>
    </div>
    <div class="topbar-right">
      <a href="/" target="_blank" class="btn btn-ghost btn-sm">🌐 View Site</a>
      <form action="/admin/logout" method="POST" style="margin:0">
        <button class="btn btn-ghost btn-sm" type="submit">Sign Out</button>
      </form>
    </div>
  </div>

  <div class="content">

    <!-- STRIPE PAYMENT LINKS -->
    <div style="background:#1B2F4E;border-radius:10px;padding:20px 24px;margin-bottom:24px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
        <span style="color:rgba(255,255,255,.5);font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase">💳 Stripe Payment Links — Copy & Send to Client</span>
        <div style="display:flex;gap:8px">
          <a href="https://chief-cornerstone-production.up.railway.app" target="_blank" style="background:rgba(139,195,74,.2);color:#8BC34A;font-size:.72rem;font-weight:700;padding:4px 10px;border-radius:6px;text-decoration:none">🌐 Live Site</a>
          <a href="https://chief-cornerstone-production.up.railway.app/admin" target="_blank" style="background:rgba(212,162,39,.2);color:#D4A227;font-size:.72rem;font-weight:700;padding:4px 10px;border-radius:6px;text-decoration:none">📊 CMS Demo</a>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:10px">

        <!-- Chief Cornerstone -->
        <div style="background:rgba(26,46,26,.8);border-radius:8px;padding:14px 16px;border:1px solid rgba(139,195,74,.3)">
          <div style="color:#8BC34A;font-size:.65rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px">Chief Cornerstone</div>
          <a href="https://buy.stripe.com/8x25kC3S172f5S4dks24000" target="_blank" style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(255,255,255,.08);border-radius:6px;text-decoration:none;margin-bottom:6px">
            <span style="color:white;font-size:.82rem;font-weight:600">Setup Fee</span>
            <span style="color:#D4A227;font-weight:800;font-size:.88rem">$797</span>
          </a>
          <a href="https://buy.stripe.com/eVqcN4609aera8ka8g24001" target="_blank" style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(255,255,255,.08);border-radius:6px;text-decoration:none">
            <span style="color:white;font-size:.82rem;font-weight:600">Monthly Hosting</span>
            <span style="color:#8BC34A;font-weight:800;font-size:.88rem">$99/mo</span>
          </a>
        </div>

        <!-- Standard Templates -->
        <div style="background:rgba(255,255,255,.04);border-radius:8px;padding:14px 16px;border:1px solid rgba(255,255,255,.1)">
          <div style="color:rgba(255,255,255,.4);font-size:.65rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px">Standard Templates</div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(255,255,255,.05);border-radius:6px;margin-bottom:6px">
            <span style="color:rgba(255,255,255,.5);font-size:.82rem">Template Package</span>
            <span style="color:#C9922B;font-weight:700;font-size:.82rem">$350 — add tomorrow</span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(255,255,255,.05);border-radius:6px;margin-bottom:6px">
            <span style="color:rgba(255,255,255,.5);font-size:.82rem">Domain Setup</span>
            <span style="color:#C9922B;font-weight:700;font-size:.82rem">$499 — add tomorrow</span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(255,255,255,.05);border-radius:6px">
            <span style="color:rgba(255,255,255,.5);font-size:.82rem">Template Launch</span>
            <span style="color:#C9922B;font-weight:700;font-size:.82rem">$797 — add tomorrow</span>
          </div>
        </div>

        <!-- Add-Ons -->
        <div style="background:rgba(255,255,255,.04);border-radius:8px;padding:14px 16px;border:1px solid rgba(255,255,255,.1)">
          <div style="color:rgba(255,255,255,.4);font-size:.65rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px">Add-Ons</div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(255,255,255,.05);border-radius:6px;margin-bottom:6px">
            <span style="color:rgba(255,255,255,.5);font-size:.82rem">Data Analytics</span>
            <span style="color:#C9922B;font-weight:700;font-size:.82rem">$750 — add tomorrow</span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(255,255,255,.05);border-radius:6px;margin-bottom:6px">
            <span style="color:rgba(255,255,255,.5);font-size:.82rem">Copy Writing</span>
            <span style="color:#C9922B;font-weight:700;font-size:.82rem">$99 — add tomorrow</span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(255,255,255,.05);border-radius:6px">
            <span style="color:rgba(255,255,255,.5);font-size:.82rem">Extra Change Request</span>
            <span style="color:#C9922B;font-weight:700;font-size:.82rem">$75 — add tomorrow</span>
          </div>
        </div>

        <!-- Custom Builds -->
        <div style="background:rgba(255,255,255,.04);border-radius:8px;padding:14px 16px;border:1px solid rgba(255,255,255,.1)">
          <div style="color:rgba(255,255,255,.4);font-size:.65rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px">Custom Builds</div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(255,255,255,.05);border-radius:6px;margin-bottom:6px">
            <span style="color:rgba(255,255,255,.5);font-size:.82rem">Basic CMS Deposit (50%)</span>
            <span style="color:#C9922B;font-weight:700;font-size:.82rem">$600 — add tomorrow</span>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:rgba(255,255,255,.05);border-radius:6px">
            <span style="color:rgba(255,255,255,.5);font-size:.82rem">Complex CMS Deposit (50%)</span>
            <span style="color:#C9922B;font-weight:700;font-size:.82rem">$1,250 — add tomorrow</span>
          </div>
        </div>

      </div>
      <div style="margin-top:12px;padding:10px 14px;background:rgba(201,146,43,.1);border-radius:8px;font-size:.78rem;color:#C9922B">
        📋 Tomorrow: Create each missing Stripe link and paste the URL here to replace "add tomorrow". Same process as Chief Cornerstone.
      </div>
    </div>

    <!-- CUSTOM ADD-ONS CHECKLIST -->
    <div style="background:#1B2F4E;border-radius:10px;padding:20px 24px;margin-bottom:24px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
        <span style="color:rgba(255,255,255,.5);font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase">🔧 Custom Add-Ons — Per Client Quote</span>
        <span style="color:rgba(255,255,255,.25);font-size:.7rem">Check boxes to note what a client has requested — save via Stripe later</span>
      </div>
      <p style="color:rgba(255,255,255,.3);font-size:.75rem;margin-bottom:16px">These are not included in the standard $99/mo plan. Each is custom-quoted and billed separately. Check the box when a client requests it, then create a Stripe payment link for the amount.</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:10px" id="addonGrid">

        <label style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:14px 16px;cursor:pointer;display:block;transition:background .15s" onclick="toggleAddon(this)">
          <div style="display:flex;align-items:flex-start;gap:10px">
            <input type="checkbox" style="margin-top:2px;accent-color:#8BC34A;width:15px;height:15px;flex-shrink:0">
            <div>
              <div style="color:white;font-size:.85rem;font-weight:700;margin-bottom:3px">📍 Route Density & Map Profitability</div>
              <div style="color:rgba(255,255,255,.4);font-size:.75rem;line-height:1.5">Which ZIP codes are most profitable after travel time? Requires Google Maps API integration.</div>
              <div style="color:#D4A227;font-size:.72rem;font-weight:700;margin-top:6px">~$30–50/mo add-on · Custom Quote</div>
            </div>
          </div>
        </label>

        <label style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:14px 16px;cursor:pointer;display:block;transition:background .15s" onclick="toggleAddon(this)">
          <div style="display:flex;align-items:flex-start;gap:10px">
            <input type="checkbox" style="margin-top:2px;accent-color:#8BC34A;width:15px;height:15px;flex-shrink:0">
            <div>
              <div style="color:white;font-size:.85rem;font-weight:700;margin-bottom:3px">🚜 Equipment ROI Tracker</div>
              <div style="color:rgba(255,255,255,.4);font-size:.75rem;line-height:1.5">Fuel, maintenance, and depreciation allocated per job type. Know exactly what each machine earns.</div>
              <div style="color:#D4A227;font-size:.72rem;font-weight:700;margin-top:6px">$150–300 setup · Custom Quote</div>
            </div>
          </div>
        </label>

        <label style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:14px 16px;cursor:pointer;display:block;transition:background .15s" onclick="toggleAddon(this)">
          <div style="display:flex;align-items:flex-start;gap:10px">
            <input type="checkbox" style="margin-top:2px;accent-color:#8BC34A;width:15px;height:15px;flex-shrink:0">
            <div>
              <div style="color:white;font-size:.85rem;font-weight:700;margin-bottom:3px">📊 QuickBooks Sync</div>
              <div style="color:rgba(255,255,255,.4);font-size:.75rem;line-height:1.5">Two-way sync with QuickBooks Online. Invoices, expenses, payroll — no double entry.</div>
              <div style="color:#D4A227;font-size:.72rem;font-weight:700;margin-top:6px">$500 setup + $25/mo</div>
            </div>
          </div>
