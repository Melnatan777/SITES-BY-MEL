<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Financials — Sites by Mel Admin</title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<div class="admin-wrap">
  <%- include('../partials/admin-nav', { activePage: 'financials' }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <h1>Financials</h1>
      <span style="font-size:.82rem;color:#6B7280;">Income, expenses, taxes & profit — <%= year %></span>
    </div>
    <div class="admin-content">

      <!-- YEAR SELECTOR -->
      <div style="margin-bottom:24px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
        <% [currentYear-1, currentYear].forEach(y => { %>
          <a href="/admin/financials?year=<%= y %>" style="padding:6px 18px;border-radius:6px;font-size:.85rem;font-weight:600;text-decoration:none;
            background:<%= y===year ? '#1B2F4E' : '#F4F2EE' %>;color:<%= y===year ? '#fff' : '#374151' %>;border:1px solid <%= y===year ? '#1B2F4E' : '#E5E0D8' %>">
            <%= y %>
          </a>
        <% }) %>
      </div>

      <!-- SUMMARY CARDS -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:28px;">
        <div style="background:#fff;border:1px solid #E5E0D8;border-radius:10px;padding:20px;">
          <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#9CA3AF;margin-bottom:6px;">Gross Revenue</div>
          <div style="font-size:1.6rem;font-weight:800;color:#15803D;">$<%= grossRevenue.toFixed(2) %></div>
          <div style="font-size:.75rem;color:#6B7280;margin-top:4px;">All paid orders</div>
        </div>
        <div style="background:#fff;border:1px solid #E5E0D8;border-radius:10px;padding:20px;">
          <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#9CA3AF;margin-bottom:6px;">Total Expenses</div>
          <div style="font-size:1.6rem;font-weight:800;color:#DC2626;">$<%= totalExpenses.toFixed(2) %></div>
          <div style="font-size:.75rem;color:#6B7280;margin-top:4px;">Logged below</div>
        </div>
        <div style="background:#fff;border:1px solid #E5E0D8;border-radius:10px;padding:20px;">
          <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#9CA3AF;margin-bottom:6px;">Net Profit</div>
          <div style="font-size:1.6rem;font-weight:800;color:<%= netProfit >= 0 ? '#1B2F4E' : '#DC2626' %>;">$<%= netProfit.toFixed(2) %></div>
          <div style="font-size:.75rem;color:#6B7280;margin-top:4px;">Revenue minus expenses</div>
        </div>
        <div style="background:#fdf6e3;border:1px solid #C9922B;border-radius:10px;padding:20px;">
          <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#9CA3AF;margin-bottom:6px;">Est. Tax Owed (<%= taxRate %>%)</div>
          <div style="font-size:1.6rem;font-weight:800;color:#C9922B;">$<%= estimatedTax.toFixed(2) %></div>
          <div style="font-size:.75rem;color:#6B7280;margin-top:4px;">Set aside from net profit</div>
        </div>
        <div style="background:#fff;border:1px solid #E5E0D8;border-radius:10px;padding:20px;">
          <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#9CA3AF;margin-bottom:6px;">Take-Home Pay</div>
          <div style="font-size:1.6rem;font-weight:800;color:#15803D;">$<%= takeHome.toFixed(2) %></div>
          <div style="font-size:.75rem;color:#6B7280;margin-top:4px;">After expenses & tax</div>
        </div>
      </div>

      <!-- TAX RATE SETTING -->
      <div style="background:#fff;border:1px solid #E5E0D8;border-radius:10px;padding:20px 24px;margin-bottom:24px;">
        <h2 style="font-size:.95rem;font-weight:700;color:#1B2F4E;margin-bottom:4px;">Tax Rate Setting</h2>
        <p style="font-size:.82rem;color:#6B7280;margin-bottom:14px;">Set your estimated self-employment tax rate. Typical range: 25–30% for sole proprietors in the US. This does not file your taxes — it just shows what to set aside.</p>
        <form method="POST" action="/admin/financials/taxrate" style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
          <input type="number" name="tax_rate" value="<%= taxRate %>" min="0" max="50" step="1"
            style="width:80px;padding:8px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;">
          <span style="font-size:.9rem;color:#374151;">%</span>
          <button type="submit" style="padding:8px 18px;background:#1B2F4E;color:#fff;border:none;border-radius:6px;font-size:.85rem;cursor:pointer;">Save Rate</button>
        </form>
      </div>

      <!-- MONTHLY BREAKDOWN -->
      <div style="background:#fff;border:1px solid #E5E0D8;border-radius:10px;padding:20px 24px;margin-bottom:24px;">
        <h2 style="font-size:.95rem;font-weight:700;color:#1B2F4E;margin-bottom:16px;">Monthly Revenue Breakdown</h2>
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;font-size:.85rem;">
            <thead>
              <tr style="border-bottom:2px solid #E5E0D8;">
                <th style="text-align:left;padding:8px 12px;color:#6B7280;font-weight:600;">Month</th>
                <th style="text-align:right;padding:8px 12px;color:#6B7280;font-weight:600;">Templates</th>
                <th style="text-align:right;padding:8px 12px;color:#6B7280;font-weight:600;">Setups</th>
                <th style="text-align:right;padding:8px 12px;color:#6B7280;font-weight:600;">Add-Ons</th>
                <th style="text-align:right;padding:8px 12px;color:#6B7280;font-weight:600;">Total</th>
              </tr>
            </thead>
            <tbody>
              <% monthlyData.forEach(function(row) { %>
              <tr style="border-bottom:1px solid #F4F2EE;">
                <td style="padding:10px 12px;font-weight:600;color:#374151;"><%= row.month %></td>
                <td style="padding:10px 12px;text-align:right;color:#374151;">$<%= row.templates.toFixed(2) %></td>
                <td style="padding:10px 12px;text-align:right;color:#374151;">$<%= row.setups.toFixed(2) %></td>
                <td style="padding:10px 12px;text-align:right;color:#374151;">$<%= row.addons.toFixed(2) %></td>
                <td style="padding:10px 12px;text-align:right;font-weight:700;color:#15803D;">$<%= row.total.toFixed(2) %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- EXPENSES -->
      <div style="background:#fff;border:1px solid #E5E0D8;border-radius:10px;padding:20px 24px;margin-bottom:24px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px;">
          <div>
            <h2 style="font-size:.95rem;font-weight:700;color:#1B2F4E;margin-bottom:2px;">Business Expenses</h2>
            <p style="font-size:.78rem;color:#6B7280;">Log your overhead here to track real profit. These reduce your taxable income.</p>
          </div>
        </div>

        <!-- Add expense form -->
        <form method="POST" action="/admin/financials/expense" style="display:grid;grid-template-columns:1fr 1fr auto auto;gap:10px;margin-bottom:20px;align-items:end;">
          <div>
            <label style="display:block;font-size:.75rem;font-weight:700;color:#374151;margin-bottom:4px;">Description</label>
            <input type="text" name="description" placeholder="e.g. Claude Pro subscription" required
              style="width:100%;padding:8px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.85rem;">
          </div>
          <div>
            <label style="display:block;font-size:.75rem;font-weight:700;color:#374151;margin-bottom:4px;">Category</label>
            <select name="category" style="width:100%;padding:8px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.85rem;background:#fff;">
              <option value="AI Tools">AI Tools (Claude, ChatGPT)</option>
              <option value="Hosting">Hosting (Railway, Cloudflare)</option>
              <option value="Domain">Domain Names</option>
              <option value="Software">Software & Subscriptions</option>
              <option value="Marketing">Marketing & Ads</option>
              <option value="Education">Education & Training</option>
              <option value="Equipment">Equipment</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:.75rem;font-weight:700;color:#374151;margin-bottom:4px;">Amount ($)</label>
            <input type="number" name="amount" placeholder="0.00" step="0.01" min="0" required
              style="width:100px;padding:8px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.85rem;">
          </div>
          <div>
            <label style="display:block;font-size:.75rem;font-weight:700;color:#374151;margin-bottom:4px;">Date</label>
            <input type="date" name="expense_date" value="<%= new Date().toISOString().slice(0,10) %>"
              style="padding:8px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.85rem;">
          </div>
          <button type="submit" style="padding:8px 18px;background:#C9922B;color:#fff;border:none;border-radius:6px;font-size:.85rem;cursor:pointer;white-space:nowrap;">+ Add</button>
        </form>

        <!-- Expense list -->
        <% if (expenses.length === 0) { %>
          <p style="color:#9CA3AF;font-size:.85rem;text-align:center;padding:20px 0;">No expenses logged yet. Add your first one above.</p>
        <% } else { %>
          <table style="width:100%;border-collapse:collapse;font-size:.85rem;">
            <thead>
              <tr style="border-bottom:2px solid #E5E0D8;">
                <th style="text-align:left;padding:8px 12px;color:#6B7280;font-weight:600;">Date</th>
                <th style="text-align:left;padding:8px 12px;color:#6B7280;font-weight:600;">Description</th>
                <th style="text-align:left;padding:8px 12px;color:#6B7280;font-weight:600;">Category</th>
                <th style="text-align:right;padding:8px 12px;color:#6B7280;font-weight:600;">Amount</th>
                <th style="padding:8px 12px;"></th>
              </tr>
            </thead>
            <tbody>
              <% expenses.forEach(function(e) { %>
              <tr style="border-bottom:1px solid #F4F2EE;">
                <td style="padding:10px 12px;color:#6B7280;"><%= e.expense_date ? e.expense_date.slice(0,10) : '' %></td>
                <td style="padding:10px 12px;color:#374151;"><%= e.description %></td>
                <td style="padding:10px 12px;"><span style="background:#F4F2EE;color:#374151;font-size:.75rem;padding:2px 8px;border-radius:100px;"><%= e.category %></span></td>
                <td style="padding:10px 12px;text-align:right;font-weight:600;color:#DC2626;">$<%= parseFloat(e.amount).toFixed(2) %></td>
                <td style="padding:10px 12px;text-align:center;">
                  <form method="POST" action="/admin/financials/expense/<%= e.id %>/delete" style="display:inline;">
                    <button type="submit" style="background:none;border:none;color:#9CA3AF;cursor:pointer;font-size:.8rem;" onclick="return confirm('Delete this expense?')">✕</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>

      <!-- OVERHEAD REFERENCE -->
      <div style="background:#F0F4F8;border:1px solid #D1D5DB;border-radius:10px;padding:20px 24px;">
        <h2 style="font-size:.95rem;font-weight:700;color:#1B2F4E;margin-bottom:12px;">Typical Monthly Overhead (for reference)</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;font-size:.85rem;">
          <div style="background:#fff;border-radius:6px;padding:12px 16px;">
            <div style="font-weight:700;color:#374151;">Claude Pro</div>
            <div style="color:#6B7280;">~$20/month</div>
          </div>
          <div style="background:#fff;border-radius:6px;padding:12px 16px;">
            <div style="font-weight:700;color:#374151;">Railway (Hobby)</div>
            <div style="color:#6B7280;">~$5/month</div>
          </div>
          <div style="background:#fff;border-radius:6px;padding:12px 16px;">
            <div style="font-weight:700;color:#374151;">Cloudflare</div>
            <div style="color:#6B7280;">Free (DNS & SSL)</div>
          </div>
          <div style="background:#fff;border-radius:6px;padding:12px 16px;">
            <div style="font-weight:700;color:#374151;">Domain (sitesbymel.com)</div>
            <div style="color:#6B7280;">~$1/month (~$12/yr)</div>
          </div>
          <div style="background:#fff;border-radius:6px;padding:12px 16px;">
            <div style="font-weight:700;color:#374151;">Resend (email)</div>
            <div style="color:#6B7280;">Free up to 3k/month</div>
          </div>
          <div style="background:#fff;border-radius:6px;padding:12px 16px;">
            <div style="font-weight:700;color:#374151;">Stripe fees</div>
            <div style="color:#6B7280;">2.9% + $0.30 per sale</div>
          </div>
        </div>
        <p style="font-size:.78rem;color:#9CA3AF;margin-top:12px;">Log these as expenses above each month so your profit numbers are accurate. Stripe fees are deducted automatically from your payouts — you can estimate them as ~3% of gross revenue.</p>
      </div>

    </div>
  </div>
</div>
</body>
</html>
