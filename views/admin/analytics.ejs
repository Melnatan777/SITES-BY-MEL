<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Analytics — Sites by Mel Admin</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <style>
    .an-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px; }
    .an-grid-2 { grid-template-columns:repeat(2,1fr); }
    .an-grid-3 { grid-template-columns:repeat(3,1fr); }
    .stat-card { background:#fff; border:1px solid #E5E0D8; border-radius:10px; padding:20px 22px; }
    .stat-label { font-size:.72rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:#6B7280; margin-bottom:6px; }
    .stat-val { font-size:1.8rem; font-weight:800; color:#1B2F4E; line-height:1; }
    .stat-val.gold { color:#C9922B; }
    .stat-sub { font-size:.78rem; color:#9CA3AF; margin-top:4px; }
    .section-card { background:#fff; border:1px solid #E5E0D8; border-radius:10px; margin-bottom:20px; overflow:hidden; }
    .section-head { padding:14px 20px; border-bottom:1px solid #E5E0D8; display:flex; align-items:center; justify-content:space-between; }
    .section-head h2 { font-size:.95rem; font-weight:700; }
    .section-body { padding:16px 20px; }
    .bar-row { display:flex; align-items:center; gap:12px; margin-bottom:10px; }
    .bar-label { font-size:.82rem; color:#374151; width:160px; flex-shrink:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .bar-track { flex:1; background:#F4F2EE; border-radius:4px; height:12px; position:relative; }
    .bar-fill { height:12px; border-radius:4px; background:#1B2F4E; }
    .bar-fill.gold { background:#C9922B; }
    .bar-fill.green { background:#16a34a; }
    .bar-num { font-size:.8rem; font-weight:700; color:#374151; width:48px; text-align:right; flex-shrink:0; }
    .day-chart { display:flex; align-items:flex-end; gap:4px; height:80px; padding-top:8px; }
    .day-bar { flex:1; background:#1B2F4E; border-radius:3px 3px 0 0; min-height:3px; position:relative; }
    .day-bar.gold { background:#C9922B; }
    .day-bar:hover::after { content:attr(data-tip); position:absolute; bottom:calc(100% + 4px); left:50%; transform:translateX(-50%); background:#1B2F4E; color:#fff; font-size:.7rem; padding:3px 7px; border-radius:4px; white-space:nowrap; z-index:10; }
    .filter-tabs { display:flex; gap:6px; }
    .filter-tab { padding:4px 12px; border-radius:100px; font-size:.78rem; font-weight:600; text-decoration:none; color:#6B7280; border:1px solid #E5E0D8; background:#fff; }
    .filter-tab.active { background:#1B2F4E; color:#fff; border-color:#1B2F4E; }
    .source-pill { display:inline-flex; align-items:center; gap:6px; background:#F4F2EE; border-radius:6px; padding:8px 14px; margin:4px; }
    .source-pill .dot { width:10px; height:10px; border-radius:50%; }
    .source-pill .dot.direct { background:#1B2F4E; }
    .source-pill .dot.google { background:#4285F4; }
    .source-pill .dot.facebook { background:#1877F2; }
    .source-pill .dot.instagram { background:#E1306C; }
    .source-pill .dot.other { background:#9CA3AF; }
    .funnel-row { display:flex; align-items:center; gap:12px; padding:10px 0; border-bottom:1px solid #F4F2EE; }
    .funnel-row:last-child { border-bottom:none; }
    .funnel-page { font-size:.85rem; color:#374151; font-weight:500; flex:1; }
    .funnel-views { font-size:.85rem; font-weight:700; color:#1B2F4E; min-width:50px; text-align:right; }
    .funnel-badge { font-size:.72rem; background:#e8f0fe; color:#1a56a8; padding:2px 8px; border-radius:4px; font-weight:600; }
    .empty { font-size:.85rem; color:#9CA3AF; padding:20px 0; text-align:center; }
    @media(max-width:900px) { .an-grid { grid-template-columns:repeat(2,1fr); } }
    @media(max-width:600px) { .an-grid, .an-grid-2, .an-grid-3 { grid-template-columns:1fr; } }
  </style>
</head>
<body>
<div class="admin-wrap">
  <%- include('../partials/admin-nav', { activePage: 'analytics' }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <h1>Analytics</h1>
      <div class="filter-tabs">
        <a href="/admin/analytics?days=7" class="filter-tab <%= days==7?'active':'' %>">7 days</a>
        <a href="/admin/analytics?days=30" class="filter-tab <%= days==30?'active':'' %>">30 days</a>
        <a href="/admin/analytics?days=90" class="filter-tab <%= days==90?'active':'' %>">90 days</a>
        <a href="/admin/analytics?days=365" class="filter-tab <%= days==365?'active':'' %>">1 year</a>
      </div>
    </div>
    <div class="admin-content">

      <!-- KPI row -->
      <div class="an-grid">
        <div class="stat-card">
          <div class="stat-label">Site Visitors</div>
          <div class="stat-val"><%= total_views.toLocaleString() %></div>
          <div class="stat-sub">Last <%= days %> days</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Revenue</div>
          <div class="stat-val gold">$<%= (revenue_total/100).toFixed(0) %></div>
          <div class="stat-sub"><%= orders_count %> template sales</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Quote Requests</div>
          <div class="stat-val"><%= new_quotes %></div>
          <div class="stat-sub"><%= won_quotes %> won</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Avg Order Value</div>
          <div class="stat-val gold">$<%= orders_count > 0 ? (revenue_total/orders_count/100).toFixed(0) : '—' %></div>
          <div class="stat-sub">Per template sale</div>
        </div>
      </div>

      <div class="an-grid an-grid-2">
        <!-- Traffic over time -->
        <div class="section-card">
          <div class="section-head"><h2>Daily Traffic</h2><span style="font-size:.78rem;color:#9CA3AF;">page views per day</span></div>
          <div class="section-body">
            <% if (views_by_day.length === 0) { %>
              <div class="empty">No traffic data yet. Visitors will appear here once people start browsing.</div>
            <% } else {
              const maxViews = Math.max(...views_by_day.map(d => d.n), 1); %>
              <div class="day-chart">
                <% views_by_day.forEach(function(d) { %>
                  <div class="day-bar" style="height:<%=Math.max(4, Math.round((d.n/maxViews)*80))%>px" data-tip="<%= d.day %>: <%= d.n %> views"></div>
                <% }); %>
              </div>
              <div style="font-size:.72rem;color:#9CA3AF;text-align:center;margin-top:6px;">Each bar = 1 day</div>
            <% } %>
          </div>
        </div>

        <!-- Revenue over time -->
        <div class="section-card">
          <div class="section-head"><h2>Daily Revenue</h2><span style="font-size:.78rem;color:#9CA3AF;">template sales</span></div>
          <div class="section-body">
            <% if (revenue_by_day.length === 0) { %>
              <div class="empty">No sales yet in this period.</div>
            <% } else {
              const maxRev = Math.max(...revenue_by_day.map(d => d.revenue), 1); %>
              <div class="day-chart">
                <% revenue_by_day.forEach(function(d) { %>
                  <div class="day-bar gold" style="height:<%=Math.max(4,Math.round((d.revenue/maxRev)*80))%>px" data-tip="<%= d.day %>: $<%= (d.revenue/100).toFixed(0) %>"></div>
                <% }); %>
              </div>
              <div style="font-size:.72rem;color:#9CA3AF;text-align:center;margin-top:6px;">Each bar = 1 day</div>
            <% } %>
          </div>
        </div>
      </div>

      <div class="an-grid an-grid-3">
        <!-- Traffic sources -->
        <div class="section-card">
          <div class="section-head"><h2>Traffic Sources</h2></div>
          <div class="section-body">
            <% if (by_source.length === 0) { %>
              <div class="empty">No data yet</div>
            <% } else {
              const totalSrc = by_source.reduce((a,b) => a+b.n, 0); %>
              <% by_source.forEach(function(s) { %>
                <div class="bar-row">
                  <div class="bar-label"><span class="source-pill" style="padding:0;background:none"><span class="dot <%= s.source %>"></span></span> <%= s.source %></div>
                  <div class="bar-track"><div class="bar-fill" style="width:<%=Math.round(s.n/totalSrc*100)%>%"></div></div>
                  <div class="bar-num"><%= s.n %></div>
                </div>
              <% }); %>
              <div style="font-size:.75rem;color:#9CA3AF;margin-top:8px;">Total: <%= totalSrc %> views tracked</div>
            <% } %>
          </div>
        </div>

        <!-- Top pages -->
        <div class="section-card">
          <div class="section-head"><h2>Top Pages</h2></div>
          <div class="section-body">
            <% if (top_pages.length === 0) { %>
              <div class="empty">No data yet</div>
            <% } else {
              const maxPg = Math.max(...top_pages.map(p => p.n), 1); %>
              <% top_pages.forEach(function(p) { %>
                <div class="bar-row">
                  <div class="bar-label" title="<%= p.path %>"><%= p.path %></div>
                  <div class="bar-track"><div class="bar-fill" style="width:<%=Math.round(p.n/maxPg*100)%>%"></div></div>
                  <div class="bar-num"><%= p.n %></div>
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>

        <!-- Quote types -->
        <div class="section-card">
          <div class="section-head"><h2>Quote Requests by Type</h2></div>
          <div class="section-body">
            <% if (quote_types.length === 0) { %>
              <div class="empty">No quote requests yet</div>
            <% } else {
              const maxQ = Math.max(...quote_types.map(q => q.n), 1); %>
              <% quote_types.forEach(function(q) { %>
                <div class="bar-row">
                  <div class="bar-label"><%= q.project_type || 'General' %></div>
                  <div class="bar-track"><div class="bar-fill gold" style="width:<%=Math.round(q.n/maxQ*100)%>%"></div></div>
                  <div class="bar-num"><%= q.n %></div>
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Purchase funnel: template page views -->
      <div class="section-card">
        <div class="section-head">
          <h2>Template Page Views — Purchase Funnel</h2>
          <span style="font-size:.78rem;color:#9CA3AF;">Which templates people are looking at before buying</span>
        </div>
        <div class="section-body">
          <% if (template_views.length === 0) { %>
            <div class="empty">No template page views yet.</div>
          <% } else { %>
            <% template_views.forEach(function(t) {
              const slug = t.path.replace('/templates/','').replace('/','');
              const sales = revenue_by_product.find(r => r.product_name && r.product_name.toLowerCase().includes(slug)) || null; %>
              <div class="funnel-row">
                <div class="funnel-page"><%= t.path %></div>
                <span class="funnel-badge"><%= t.n %> views</span>
                <% if (sales) { %>
                  <span class="funnel-badge" style="background:#e6f4ec;color:#15803d;"><%= sales.sales %> sales</span>
                <% } %>
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>

      <!-- Revenue by product -->
      <div class="section-card">
        <div class="section-head"><h2>Revenue by Template</h2></div>
        <div class="section-body">
          <% if (revenue_by_product.length === 0) { %>
            <div class="empty">No sales yet in this period.</div>
          <% } else {
            const maxRvP = Math.max(...revenue_by_product.map(r => r.revenue), 1); %>
            <% revenue_by_product.forEach(function(r) { %>
              <div class="bar-row">
                <div class="bar-label"><%= r.product_name %></div>
                <div class="bar-track"><div class="bar-fill green" style="width:<%=Math.round(r.revenue/maxRvP*100)%>%"></div></div>
                <div class="bar-num">$<%= (r.revenue/100).toFixed(0) %></div>
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</div>
</body>
</html>
