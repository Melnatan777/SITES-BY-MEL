<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ZIP Instructions Editor — Admin</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="admin-wrap">
  <%- include('../partials/admin-nav', { activePage: 'instructions' }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <h1>ZIP Instructions Editor</h1>
      <form action="/admin/logout" method="POST" style="margin:0">
        <button class="btn btn-outline btn-sm">Sign Out</button>
      </form>
    </div>
    <div class="admin-content">

      <div style="background:#fffdf7;border:1px solid #f0d080;border-radius:8px;padding:14px 18px;margin-bottom:24px;font-size:.85rem;color:#7d5a00">
        <strong>These are the instructions included inside every template ZIP.</strong> Edit the text here, save, then hit <strong>Rebuild Zips</strong> on the dashboard to apply your changes to all downloads.
      </div>

      <% if (saved) { %>
      <div style="background:#dcfce7;border:1px solid #86efac;border-radius:8px;padding:12px 18px;margin-bottom:20px;color:#166534;font-size:.88rem">
        ✓ Saved! Hit <strong>Rebuild Zips</strong> on the dashboard to apply to all ZIPs.
      </div>
      <% } %>

      <form method="POST" action="/admin/instructions">

        <div style="display:flex;flex-direction:column;gap:20px">

          <div style="background:#fff;border:1px solid var(--border);border-radius:10px;padding:24px">
            <label style="display:block;font-size:.82rem;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Step 1 — Save & Unzip Tip</label>
            <textarea name="tip_unzip" rows="3" style="width:100%;padding:10px;border:1px solid var(--border);border-radius:6px;font-size:.88rem;resize:vertical;font-family:inherit"><%= settings.tip_unzip || '' %></textarea>
            <p style="font-size:.72rem;color:var(--gray);margin-top:4px">Shown as the tip box after Step 1 (unzip & preview).</p>
          </div>

          <div style="background:#fff;border:1px solid var(--border);border-radius:10px;padding:24px">
            <label style="display:block;font-size:.82rem;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Step 2 — Save & Refresh Tip</label>
            <textarea name="tip_save" rows="3" style="width:100%;padding:10px;border:1px solid var(--border);border-radius:6px;font-size:.88rem;resize:vertical;font-family:inherit"><%= settings.tip_save || '' %></textarea>
            <p style="font-size:.72rem;color:var(--gray);margin-top:4px">Shown at the bottom of the editing steps.</p>
          </div>

          <div style="background:#fff;border:1px solid var(--border);border-radius:10px;padding:24px">
            <label style="display:block;font-size:.82rem;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Photo Section — Main Tip</label>
            <textarea name="tip_photos" rows="4" style="width:100%;padding:10px;border:1px solid var(--border);border-radius:6px;font-size:.88rem;resize:vertical;font-family:inherit"><%= settings.tip_photos || '' %></textarea>
            <p style="font-size:.72rem;color:var(--gray);margin-top:4px">Shown as the tip box in the Photos section.</p>
          </div>

          <div style="background:#fff;border:1px solid var(--border);border-radius:10px;padding:24px">
            <label style="display:block;font-size:.82rem;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Contact Form Instructions</label>
            <textarea name="tip_formspree" rows="4" style="width:100%;padding:10px;border:1px solid var(--border);border-radius:6px;font-size:.88rem;resize:vertical;font-family:inherit"><%= settings.tip_formspree || '' %></textarea>
            <p style="font-size:.72rem;color:var(--gray);margin-top:4px">Step 3 — activating the contact form via Formspree.</p>
          </div>

          <div style="background:#fff;border:1px solid var(--border);border-radius:10px;padding:24px">
            <label style="display:block;font-size:.82rem;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Get Online (Netlify Drop) Tip</label>
            <textarea name="tip_netlify" rows="3" style="width:100%;padding:10px;border:1px solid var(--border);border-radius:6px;font-size:.88rem;resize:vertical;font-family:inherit"><%= settings.tip_netlify || '' %></textarea>
            <p style="font-size:.72rem;color:var(--gray);margin-top:4px">Shown after the Netlify Drop steps.</p>
          </div>

          <div style="background:#fff;border:1px solid var(--border);border-radius:10px;padding:24px">
            <label style="display:block;font-size:.82rem;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Closing / Thank You Message</label>
            <textarea name="tip_closing" rows="3" style="width:100%;padding:10px;border:1px solid var(--border);border-radius:6px;font-size:.88rem;resize:vertical;font-family:inherit"><%= settings.tip_closing || '' %></textarea>
            <p style="font-size:.72rem;color:var(--gray);margin-top:4px">Appears at the very bottom of the instructions.</p>
          </div>

        </div>

        <div style="margin-top:24px;display:flex;gap:12px">
          <button type="submit" class="btn btn-gold">Save Instructions</button>
          <form method="POST" action="/admin/rebuild-downloads" style="margin:0">
            <button type="submit" class="btn btn-outline">Rebuild Zips Now →</button>
          </form>
        </div>
      </form>

    </div>
  </div>
</div>
</body>
</html>
