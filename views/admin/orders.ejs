<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Orders — Admin</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="admin-wrap">
  <%- include('../partials/admin-nav', { activePage: 'orders' }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <h1>Template Orders</h1>
      <form action="/admin/logout" method="POST" style="margin:0;">
        <button class="btn btn-outline btn-sm">Sign Out</button>
      </form>
    </div>
    <div class="admin-content">
      <div class="admin-table-wrap">
        <% if (orders.length === 0) { %>
          <p style="padding:40px;text-align:center;color:var(--gray);">No orders yet.</p>
        <% } else { %>
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Date</th>
              <th>Product</th>
              <th>Customer</th>
              <th>Amount</th>
              <th>Add-On</th>
              <th>Coupon</th>
              <th>Status</th>
              <th>Photos</th>
              <th>Downloads</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(function(o) { %>
            <tr>
              <td style="color:var(--gray);font-size:0.82rem;">#<%= o.id %></td>
              <td style="color:var(--gray);font-size:0.82rem;"><%= o.created_at ? o.created_at.substring(0,10) : '—' %></td>
              <td>
                <strong style="font-size:0.88rem;"><%= o.product_name %></strong><br/>
                <span style="font-size:0.75rem;color:var(--gray);"><%= o.customer_name || '—' %></span><br/>
                <span style="font-size:0.75rem;color:var(--gray);"><%= o.customer_email || '' %></span>
              </td>
              <td style="font-size:.82rem;color:var(--gray)">$<%= ((o.amount || 0) / 100).toFixed(2) %></td>
              <td>
                <% const addonLabels = {none:'—',upload:'Photo & Colors',glove:'Done-For-You'}; %>
                <span style="font-size:.78rem;font-weight:600;color:<%= o.selected_addon && o.selected_addon!='none' ? 'var(--gold)' : 'var(--gray)' %>">
                  <%= addonLabels[o.selected_addon] || o.selected_addon || '—' %>
                </span>
              </td>
              <td>
                <% if (o.coupon_code) { %>
                  <span style="font-family:monospace;font-size:.75rem;font-weight:700;color:#166534;background:#f0fdf4;padding:2px 6px;border-radius:4px"><%= o.coupon_code %></span>
                  <span style="display:block;font-size:.7rem;color:var(--gray);margin-top:2px">−$<%= ((o.discount_amount||0)/100).toFixed(2) %></span>
                <% } else { %>
                  <span style="color:var(--gray);font-size:.78rem">—</span>
                <% } %>
              </td>
              <td><span class="badge <%= o.status === 'paid' ? 'badge-green' : o.status === 'refunded' ? 'badge-red' : 'badge-yellow' %>"><%= o.status %></span></td>
              <td style="min-width:140px">
                <% var photos = photosByOrder[o.id] || []; %>
                <% if (photos.length === 0) { %>
                  <span style="font-size:.75rem;color:#9CA3AF">No photos</span>
                <% } else { %>
                  <div style="display:flex;flex-wrap:wrap;gap:6px">
                    <% photos.forEach(function(ph) { %>
                    <div style="position:relative">
                      <a href="/admin/order-photo/<%= ph.id %>" target="_blank">
                        <img src="/admin/order-photo/<%= ph.id %>" alt="<%= ph.original %>" style="width:48px;height:48px;object-fit:cover;border-radius:4px;border:1px solid var(--border)">
                      </a>
                      <form method="POST" action="/admin/order-photo/<%= ph.id %>/delete" style="margin:0" onsubmit="return confirm('Delete this photo?')">
                        <button type="submit" style="position:absolute;top:-5px;right:-5px;width:16px;height:16px;border-radius:50%;background:#ef4444;color:#fff;border:none;cursor:pointer;font-size:10px;line-height:1;padding:0">×</button>
                      </form>
                    </div>
                    <% }); %>
                  </div>
                  <span style="font-size:.72rem;color:var(--gray);display:block;margin-top:4px"><%= photos.length %> photo<%= photos.length > 1 ? 's' : '' %></span>
                <% } %>
                <% if (o.brand_colors) { %>
                  <p style="font-size:.72rem;color:#C9922B;font-weight:600;margin-top:6px;max-width:200px">Colors: <%= o.brand_colors %></p>
                <% } %>
                <% if (o.photo_notes) { %>
                  <p style="font-size:.72rem;color:#374151;margin-top:4px;font-style:italic;max-width:200px"><%= o.photo_notes %></p>
                <% } %>
              </td>
              <td style="text-align:center;color:var(--gray);"><%= o.download_count || 0 %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>

      <!-- Revenue summary -->
      <% if (orders.length > 0) { %>
      <div style="background:var(--white);border:1px solid var(--border);border-radius:8px;padding:20px;display:flex;gap:32px;flex-wrap:wrap;">
        <div>
          <p style="font-size:0.78rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.06em;">Total Orders</p>
          <p style="font-size:1.4rem;font-family:'Playfair Display',serif;font-weight:700;"><%= orders.length %></p>
        </div>
        <div>
          <p style="font-size:0.78rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.06em;">Paid Orders</p>
          <p style="font-size:1.4rem;font-family:'Playfair Display',serif;font-weight:700;"><%= orders.filter(o => o.status === 'paid').length %></p>
        </div>
        <div>
          <p style="font-size:0.78rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.06em;">Total Revenue</p>
          <p style="font-size:1.4rem;font-family:'Playfair Display',serif;font-weight:700;">$<%= (orders.filter(o => o.status === 'paid').reduce((sum, o) => sum + (o.amount||0), 0) / 100).toFixed(2) %></p>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>
</body>
</html>
