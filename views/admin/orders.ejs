<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Orders — Admin</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="admin-wrap">
  <%- include('../partials/admin-nav', { activePage: 'orders' }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <h1>Template Orders</h1>
      <form action="/admin/logout" method="POST" style="margin:0;">
        <button class="btn btn-outline btn-sm">Sign Out</button>
      </form>
    </div>
    <div class="admin-content">
      <% if (orders.length === 0) { %>
        <p style="padding:40px;text-align:center;color:var(--gray);">No orders yet.</p>
      <% } else { %>
      <div style="display:flex;flex-direction:column;gap:12px;">
        <% orders.forEach(function(o) { %>
        <% var photos = photosByOrder[o.id] || []; %>
        <a href="/admin/orders/<%= o.id %>" style="text-decoration:none;color:inherit">
        <div style="background:#fff;border:1px solid var(--border);border-radius:10px;padding:18px 24px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;cursor:pointer;transition:box-shadow .15s" onmouseover="this.style.boxShadow='0 2px 12px rgba(0,0,0,0.08)'" onmouseout="this.style.boxShadow=''">
          <div style="min-width:32px;text-align:center">
            <span style="font-size:.78rem;color:var(--gray);font-weight:700">#<%= o.id %></span>
          </div>
          <div style="flex:1;min-width:160px">
            <p style="font-weight:700;font-size:.95rem;color:#1B2F4E;margin:0"><%= o.product_name %></p>
            <p style="font-size:.8rem;color:var(--gray);margin:2px 0 0"><%= o.customer_name || '—' %> &bull; <%= o.customer_email || '' %></p>
          </div>
          <div style="text-align:center;min-width:70px">
            <p style="font-weight:700;color:#1B2F4E;margin:0">$<%= ((o.amount||0)/100).toFixed(2) %></p>
            <p style="font-size:.72rem;color:var(--gray);margin:2px 0 0"><%= o.created_at ? o.created_at.substring(0,10) : '' %></p>
          </div>
          <div style="min-width:110px">
            <% const addonLabels = {none:'—',upload:'Photo & Colors',glove:'Done-For-You'}; %>
            <span style="font-size:.78rem;font-weight:600;color:<%= o.selected_addon && o.selected_addon!='none' ? 'var(--gold)' : 'var(--gray)' %>">
              <%= addonLabels[o.selected_addon] || o.selected_addon || '—' %>
            </span>
          </div>
          <div>
            <span class="badge <%= o.status === 'completed' ? 'badge-green' : o.status === 'paid' ? 'badge-yellow' : 'badge-red' %>"><%= o.status %></span>
          </div>
          <div style="display:flex;gap:6px;align-items:center">
            <% if (photos.length > 0) { %>
              <% photos.slice(0,3).forEach(function(ph) { %>
                <img src="/admin/order-photo/<%= ph.id %>" style="width:36px;height:36px;object-fit:cover;border-radius:4px;border:1px solid var(--border)">
              <% }); %>
              <% if (photos.length > 3) { %><span style="font-size:.75rem;color:var(--gray)">+<%= photos.length-3 %></span><% } %>
            <% } else { %>
              <span style="font-size:.75rem;color:#9CA3AF">No photos</span>
            <% } %>
          </div>
          <div style="color:var(--gray);font-size:.8rem">→</div>
        </div>
        </a>
        <% }) %>
      </div>

      <div style="background:var(--white);border:1px solid var(--border);border-radius:8px;padding:20px;display:flex;gap:32px;flex-wrap:wrap;margin-top:24px">
        <div>
          <p style="font-size:0.78rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.06em;">Total Orders</p>
          <p style="font-size:1.4rem;font-family:'Playfair Display',serif;font-weight:700;"><%= orders.length %></p>
        </div>
        <div>
          <p style="font-size:0.78rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.06em;">Paid Orders</p>
          <p style="font-size:1.4rem;font-family:'Playfair Display',serif;font-weight:700;"><%= orders.filter(o => o.status === 'paid').length %></p>
        </div>
        <div>
          <p style="font-size:0.78rem;color:var(--gray);text-transform:uppercase;letter-spacing:0.06em;">Total Revenue</p>
          <p style="font-size:1.4rem;font-family:'Playfair Display',serif;font-weight:700;">$<%= (orders.filter(o => o.status === 'paid').reduce((sum, o) => sum + (o.amount||0), 0) / 100).toFixed(2) %></p>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>
</body>
</html>
