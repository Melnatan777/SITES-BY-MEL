<%- include('partials/head', { title: 'Set Up Your Service Pro Website — Sites by Mel', metaDesc: 'Tell us about your home services business and upload your photos. We\'ll build your ready-to-launch website.' }) %>
<%- include('partials/nav', { activePage: 'templates' }) %>

<section style="padding:60px 0 100px;background:#F4F2EE;min-height:80vh">
  <div style="max-width:720px;margin:0 auto;padding:0 24px">

    <div style="text-align:center;margin-bottom:36px">
      <p style="color:#C9922B;font-size:.78rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin-bottom:8px">Service Pro Template</p>
      <h1 style="font-size:1.9rem;font-weight:800;color:#1B2F4E;margin-bottom:10px">Tell Us About Your Business</h1>
      <p style="color:#6B7280;line-height:1.7;max-width:500px;margin:0 auto">Fill in as much as you can. Mel will use everything you provide to build your personalized website. You'll receive your download link within 48 hours.</p>
    </div>

    <form method="POST" action="/personalize/<%= token %>" enctype="multipart/form-data">

      <div style="max-width:780px;margin:0 auto 0;padding:0 24px;">
        <div style="background:#EFF6FF;border:1px solid #BFDBFE;border-radius:8px;padding:14px 18px;margin:24px 0 8px;font-size:0.88rem;color:#1E40AF;line-height:1.6;">
          <strong>Tip:</strong> Not sure what to write? Check <em>"Let Mel handle this"</em> on any field and she'll craft professional copy that fits your business perfectly. You can also check it on photo slots if you'd like Mel to use a great stock photo instead.
        </div>
      </div>

      <!-- ── SECTION 1: THE BASICS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">1 — The Basics</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Business Name <span style="color:#ef4444">*</span></label>
          <input type="text" name="businessName" placeholder="e.g. Rivera Pressure Washing" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Your Name <span style="color:#ef4444">*</span></label>
          <input type="text" name="yourName" placeholder="e.g. Carlos Rivera" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Trade / Specialty <span style="color:#ef4444">*</span></label>
          <input type="text" name="trade" placeholder="e.g. Pressure Washing, HVAC, Plumbing, Electrical, General Handyman" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Used across your site to describe what you do</p>
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Tagline / Slogan</label>
          <input type="text" name="tagline" placeholder="e.g. Clean Homes. Happy Neighbors." style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Leave blank — Mel will write professional copy</p>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Phone Number <span style="color:#ef4444">*</span></label>
            <input type="tel" name="phone" placeholder="(555) 000-0000" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Business Email <span style="color:#ef4444">*</span></label>
            <input type="email" name="email" placeholder="you@yourbusiness.com" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>

        <div style="display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Street Address</label>
            <input type="text" name="address" placeholder="Leave blank if you come to the customer" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">City <span style="color:#ef4444">*</span></label>
            <input type="text" name="city" placeholder="Austin" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">State & Zip</label>
            <input type="text" name="stateZip" placeholder="TX 78701" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Service Area</label>
            <input type="text" name="serviceArea" placeholder="e.g. Austin, Round Rock, Cedar Park" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
            <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Cities or zip codes you serve</p>
          </div>
        </div>
      </div>

      <!-- ── SECTION 2: HOURS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">2 — Your Hours</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Monday – Friday</label>
            <input type="text" name="hoursMF" placeholder="7am – 6pm" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Saturday</label>
            <input type="text" name="hoursSat" placeholder="8am – 4pm" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Sunday</label>
            <input type="text" name="hoursSun" placeholder="Closed" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>
      </div>

      <!-- ── SECTION 3: TRUST DETAILS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">3 — Trust & Credentials</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:8px;color:#374151">Licensed & Insured?</label>
            <div style="display:flex;gap:20px">
              <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
                <input type="radio" name="licensedInsured" value="yes"> Yes
              </label>
              <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
                <input type="radio" name="licensedInsured" value="no"> No
              </label>
            </div>
            <p style="font-size:.72rem;color:#9CA3AF;margin-top:5px">Shown as a trust badge on your site if "Yes"</p>
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:8px;color:#374151">Free Estimates?</label>
            <div style="display:flex;gap:20px">
              <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
                <input type="radio" name="freeEstimates" value="yes"> Yes
              </label>
              <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
                <input type="radio" name="freeEstimates" value="no"> No
              </label>
            </div>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:8px;color:#374151">Emergency / Same-Day Service?</label>
            <div style="display:flex;gap:20px">
              <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
                <input type="radio" name="emergencyService" value="yes"> Yes
              </label>
              <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
                <input type="radio" name="emergencyService" value="no"> No
              </label>
            </div>
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Years in Business</label>
            <input type="text" name="yearsExp" placeholder="e.g. 10+" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>

        <div>
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Jobs Completed (stat)</label>
          <input type="text" name="jobsCompleted" placeholder="e.g. 1,200+ jobs" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Leave blank — Mel will write a placeholder stat</p>
        </div>
      </div>

      <!-- ── SECTION 4: SERVICES & PRICING ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">4 — Services & Pricing</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <% var services = [
          { num: 1, namePh: 'Driveway & Sidewalk Cleaning', pricePh: 'Starting at $149', nameField: 'svc1Name', priceField: 'svc1Price', descField: 'svc1Desc', descPh: 'High-pressure cleaning that removes years of grime, oil stains, and mildew...' },
          { num: 2, namePh: 'House Exterior Wash', pricePh: 'Starting at $299', nameField: 'svc2Name', priceField: 'svc2Price', descField: 'svc2Desc', descPh: 'Soft-wash treatment safe for all siding types. Removes algae, mold, and buildup...' },
          { num: 3, namePh: 'Deck & Patio Restoration', pricePh: 'Starting at $199', nameField: 'svc3Name', priceField: 'svc3Price', descField: 'svc3Desc', descPh: 'Strip years of weathering and prep your deck or patio for staining or sealing...' },
        ]; %>

        <% services.forEach(function(s) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:18px;margin-bottom:14px">
          <p style="font-size:.78rem;font-weight:700;color:#C9922B;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px">Service <%= s.num %></p>
          <div style="display:grid;grid-template-columns:2fr 1fr;gap:12px;margin-bottom:10px">
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Service Name</label>
              <input type="text" name="<%= s.nameField %>" placeholder="<%= s.namePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Starting Price</label>
              <input type="text" name="<%= s.priceField %>" placeholder="<%= s.pricePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
          </div>
          <div>
            <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Short Description</label>
            <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-bottom:6px;cursor:pointer;">
              <input type="checkbox" name="mel_<%= s.descField %>" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
              Let Mel handle this
            </label>
            <textarea name="<%= s.descField %>" rows="2" placeholder="<%= s.descPh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;resize:vertical;box-sizing:border-box"></textarea>
          </div>
        </div>
        <% }); %>

      </div>

      <!-- ── SECTION 5: TESTIMONIALS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">5 — Customer Testimonials</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#f0f4ff;border-radius:8px;padding:12px 16px;margin-bottom:18px;font-size:.82rem;color:#374151;line-height:1.6">
          <strong>No reviews yet?</strong> Leave these blank and Mel will remove the placeholder testimonials from your site.
        </div>

        <% var testimonials = [
          { num: 1, namePh: 'Dave & Lisa H.', resultPh: 'Driveway Cleaning — Austin, TX', quotePh: '"Our driveway looks brand new. Showed up on time and left the place spotless..."', nameField: 'test1Name', resultField: 'test1Result', quoteField: 'test1Quote' },
          { num: 2, namePh: 'Priya K.', resultPh: 'House Exterior Wash', quotePh: '"Couldn\'t believe the difference. The algae and dark stains are completely gone..."', nameField: 'test2Name', resultField: 'test2Result', quoteField: 'test2Quote' },
          { num: 3, namePh: 'Tom R.', resultPh: 'Deck Restoration', quotePh: '"Best money I\'ve spent on my home all year. Deck looks like it was just built..."', nameField: 'test3Name', resultField: 'test3Result', quoteField: 'test3Quote' },
        ]; %>

        <% testimonials.forEach(function(t) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:18px;margin-bottom:14px">
          <p style="font-size:.78rem;font-weight:700;color:#C9922B;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px">Testimonial <%= t.num %></p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:10px">
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Homeowner Name</label>
              <input type="text" name="<%= t.nameField %>" placeholder="<%= t.namePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Job Type / Location</label>
              <input type="text" name="<%= t.resultField %>" placeholder="<%= t.resultPh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
          </div>
          <div>
            <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Their Quote</label>
            <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-bottom:6px;cursor:pointer;">
              <input type="checkbox" name="mel_<%= t.quoteField %>" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
              Let Mel handle this
            </label>
            <textarea name="<%= t.quoteField %>" rows="2" placeholder="<%= t.quotePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;resize:vertical;box-sizing:border-box"></textarea>
          </div>
        </div>
        <% }); %>

      </div>

      <!-- ── SECTION 6: BEFORE & AFTER ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">6 — Before & After Labels</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <p style="font-size:.82rem;color:#374151;margin-bottom:18px;line-height:1.6">Label each before/after pair with what job it shows. Upload the photos in the section below.</p>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Before/After Pair #1 — Job Label</label>
            <input type="text" name="baPair1Label" placeholder="e.g. Driveway Cleaning" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Before/After Pair #2 — Job Label</label>
            <input type="text" name="baPair2Label" placeholder="e.g. House Exterior" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>
      </div>

      <!-- ── SECTION 7: CONTACT FORM ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">7 — Contact Form</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

      </div>

      <!-- ── SECTION 8: PHOTOS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">8 — Your Photos</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#f0f4ff;border-radius:8px;padding:14px 18px;margin-bottom:22px;font-size:.82rem;color:#374151;line-height:1.7">
          <strong>Photo tips:</strong> JPG or PNG only. Landscape photos (wider than tall) work best for banners. Files under 2MB load fastest.<br>
          <strong>Don't have photos yet?</strong> Leave any slot blank — Mel will leave a styled placeholder and you can swap it in later.
        </div>

        <% var photos = [
          { field: 'photoHero', label: 'Hero Photo — Your Best Work or Truck/Equipment', desc: 'The big image at the top of your home page. Show your best completed job, your vehicle/equipment, or you on the job.', size: '1600×900 (landscape)' },
          { field: 'photoTeam', label: 'You / Your Team on a Job', desc: 'A photo of you or your crew actively working on a job. Builds trust and makes your site feel real.', size: '800×600 (landscape)' },
          { field: 'photoBefore1', label: 'Before Photo #1', desc: 'The "before" photo for your first before/after pair. Match the label you entered above.', size: '800×600 (landscape)' },
          { field: 'photoAfter1', label: 'After Photo #1', desc: 'The "after" photo for your first before/after pair.', size: '800×600 (landscape)' },
          { field: 'photoBefore2', label: 'Before Photo #2', desc: 'The "before" photo for your second before/after pair.', size: '800×600 (landscape)' },
          { field: 'photoAfter2', label: 'After Photo #2', desc: 'The "after" photo for your second before/after pair.', size: '800×600 (landscape)' },
          { field: 'photoLogo', label: 'Your Logo', desc: 'Your business logo. PNG with transparent background is preferred.', size: 'PNG, transparent background preferred' },
        ]; %>

        <% photos.forEach(function(p) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:16px 18px;margin-bottom:12px">
          <label style="display:block;font-size:.85rem;font-weight:700;color:#1B2F4E;margin-bottom:4px"><%= p.label %></label>
          <p style="font-size:.78rem;color:#6B7280;margin:0 0 8px;line-height:1.5"><%= p.desc %></p>
          <p style="font-size:.72rem;color:#9CA3AF;margin:0 0 8px">Best size: <strong><%= p.size %></strong></p>
          <input type="file" name="<%= p.field %>" accept="image/jpeg,image/png,image/webp" style="font-size:.82rem;color:#374151">
          <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-top:6px;cursor:pointer;">
            <input type="checkbox" name="mel_stock_<%= p.field %>" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
            Use a professional stock photo instead
          </label>
        </div>
        <% }); %>

      </div>

      <!-- ── SECTION 9: NOTES FOR MEL ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">9 — Anything Else for Mel?</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:28px">
