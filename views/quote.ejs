<%- include('partials/head', { title: 'Get a Quote — Sites by Mel', metaDesc: "Tell me what you need and I will put together a custom quote for your new website." }) %>
<%- include('partials/nav', { activePage: 'contact' }) %>

<section style="padding:80px 0 60px;background:#F4F2EE;min-height:80vh">
  <div style="max-width:760px;margin:0 auto;padding:0 24px;text-align:center">
    <h1 style="font-size:2.2rem;font-weight:800;color:var(--navy);margin-bottom:12px">What kind of site do you need?</h1>
    <p style="color:#6B7280;line-height:1.7;max-width:520px;margin:0 auto 48px">Choose the option that fits your situation. Both include a free quote with no obligation.</p>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;text-align:left">

      <!-- Simple site option -->
      <div style="background:#fff;border:1px solid #E5E0D8;border-radius:14px;padding:32px;display:flex;flex-direction:column">
        <div style="width:48px;height:48px;background:#F4F2EE;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:18px">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
          </svg>
        </div>
        <h2 style="font-size:1.2rem;font-weight:700;color:var(--navy);margin-bottom:8px">Simple Website</h2>
        <p style="font-size:.88rem;color:#6B7280;line-height:1.7;flex:1">A beautiful, fast, mobile-friendly website for your business. No login, no database — just a great site that loads instantly and converts visitors.</p>
        <div style="background:#F4F2EE;border-radius:8px;padding:12px 14px;margin:18px 0;font-size:.82rem;color:#374151;line-height:1.7">
          <strong style="display:block;margin-bottom:4px">Good for:</strong>
          Service businesses, restaurants, shops, realtors, churches, creators
        </div>
        <div style="font-size:.82rem;color:#9CA3AF;margin-bottom:20px">
          Starting at <strong style="color:var(--navy)">$797</strong> &bull; Delivered in 3–5 days
        </div>
        <a href="/quote/simple" style="display:block;text-align:center;background:var(--navy);color:#fff;padding:12px 20px;border-radius:8px;text-decoration:none;font-weight:700;font-size:.95rem">Get a Simple Site Quote &rarr;</a>
      </div>

      <!-- Full CMS option -->
      <div style="background:#1B2F4E;border-radius:14px;padding:32px;display:flex;flex-direction:column;position:relative;overflow:hidden">
        <div style="position:absolute;top:16px;right:16px;background:#C9922B;color:#fff;font-size:.7rem;font-weight:700;padding:3px 10px;border-radius:100px;letter-spacing:.05em;text-transform:uppercase">Most Powerful</div>
        <div style="width:48px;height:48px;background:rgba(255,255,255,.1);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:18px">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#C9922B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h2 style="font-size:1.2rem;font-weight:700;color:#fff;margin-bottom:8px">Full Custom Site + Admin Dashboard</h2>
        <p style="font-size:.88rem;color:rgba(255,255,255,.65);line-height:1.7;flex:1">A fully custom-built website with your own admin panel. Manage content, view leads, track orders, run analytics — all from a private dashboard only you can access.</p>
        <div style="background:rgba(255,255,255,.07);border-radius:8px;padding:12px 14px;margin:18px 0;font-size:.82rem;color:rgba(255,255,255,.75);line-height:1.7">
          <strong style="display:block;margin-bottom:4px;color:#C9922B">Good for:</strong>
          Online stores, booking systems, churches with giving/sermons, blogs, businesses with complex needs
        </div>
        <div style="font-size:.82rem;color:rgba(255,255,255,.4);margin-bottom:20px">
          Starting at <strong style="color:#C9922B">$1,500</strong> &bull; Custom timeline
        </div>
        <a href="/quote/full" style="display:block;text-align:center;background:#C9922B;color:#fff;padding:12px 20px;border-radius:8px;text-decoration:none;font-weight:700;font-size:.95rem">Get a Full Site Quote &rarr;</a>
      </div>
    </div>

    <p style="margin-top:32px;font-size:.85rem;color:#9CA3AF">Not sure which one? <a href="/contact" style="color:var(--gold);text-decoration:none">Send me a message</a> and I will help you figure it out.</p>
  </div>
</section>

<%- include('partials/footer') %>
