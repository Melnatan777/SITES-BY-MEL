<%- include('partials/head', { title: 'Order Complete', metaDesc: 'Your purchase is complete. Download your website template now.' }) %>
<%- include('partials/nav') %>

<section class="section">
  <div class="container">
    <% if (order && downloadUrl) { %>
    <div class="success-box">
      <div class="success-icon">🎉</div>
      <h1>You're all set!</h1>
      <p style="font-size:1.05rem;">Thanks for purchasing <strong><%= order.product_name %></strong>. Your download link is ready.</p>
      <p style="color:var(--gray);font-size:0.9rem;margin-top:4px;">A copy of this link has been emailed to you. It's valid for <strong>48 hours</strong>.</p>
      <a href="<%= downloadUrl %>" class="download-link">⬇ Download Your Template</a>
      <div style="margin-top:28px;padding:20px;background:var(--light);border-radius:6px;text-align:left;max-width:480px;margin-left:auto;margin-right:auto;">
        <h3 style="font-size:0.95rem;margin-bottom:12px;">What's next?</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
          <li style="font-size:0.88rem;color:var(--gray);">✓ Unzip the folder and save it on your computer</li>
          <li style="font-size:0.88rem;color:var(--gray);">✓ Open <code>INSTRUCTIONS.html</code> first — it walks you through everything</li>
          <li style="font-size:0.88rem;color:var(--gray);">✓ A setup assistant is built right into your template to guide you step by step</li>
          <li style="font-size:0.88rem;color:var(--gray);">✓ When you're ready, drag your folder to Netlify and go live free</li>
        </ul>
      </div>

      <div style="margin-top:24px;background:#1B2F4E;border-radius:10px;padding:22px 28px;max-width:480px;margin-left:auto;margin-right:auto;text-align:left">
        <p style="color:#C9922B;font-weight:700;font-size:.95rem;margin-bottom:6px">🤖 Step-by-step help is built in</p>
        <p style="color:rgba(255,255,255,0.85);font-size:.84rem;line-height:1.7;margin-bottom:14px">Your ZIP includes a setup assistant that knows your exact template. Open any page in your browser and look for the chat bubble in the bottom right corner — it will walk you through every single change, one step at a time.</p>
        <p style="color:rgba(255,255,255,0.85);font-size:.84rem;line-height:1.7"><strong style="color:#C9922B">How to use it:</strong> Open the HTML file in <strong>Notepad</strong> to edit, and open the same file in your <strong>browser</strong> to preview and get help. Keep both open side by side!</p>
      </div>

      <p style="margin-top:24px;font-size:0.88rem;color:var(--gray);">Still stuck? <a href="/contact" style="color:var(--navy);font-weight:600">Message Mel directly</a> — or upgrade to <a href="/services" style="color:var(--navy);font-weight:600">Done-For-You setup</a> and she'll handle everything.</p>
    </div>
    <% } else { %>
    <div class="success-box">
      <div class="success-icon">🤔</div>
      <h1>Hmm, that order wasn't found.</h1>
      <p style="color:var(--gray);">This can happen if you navigated here directly. Check your email for the download link, or <a href="/contact">contact me</a> and I'll sort it out.</p>
      <div style="margin-top:24px;">
        <a href="/templates" class="btn btn-navy">Back to Templates</a>
      </div>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
