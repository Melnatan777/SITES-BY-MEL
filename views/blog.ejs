<%- include('partials/head', { title: 'Blog — Sites by Mel', metaDesc: 'Weekly tips on websites, SEO, Google, and growing your small business online.' }) %>
<%- include('partials/nav', { activePage: 'blog' }) %>

<div class="page-header">
  <div class="container">
    <h1>Small Business Tips &amp; Insights</h1>
    <p style="margin-top:8px;opacity:.8;max-width:520px">Weekly posts on websites, SEO, Google, and what actually grows a local business online.</p>
  </div>
</div>

<section class="section">
  <div class="container">

    <!-- FEATURED POST -->
    <div style="background:#fff;border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:48px;display:grid;grid-template-columns:1fr 1fr;min-height:320px;" class="blog-featured">
      <div style="background:linear-gradient(135deg,var(--navy) 0%,#2d4a6e 100%);display:flex;align-items:center;justify-content:center;padding:40px;">
        <div style="text-align:center">
          <div style="font-size:3.5rem;margin-bottom:16px">✍️</div>
          <span style="background:var(--gold);color:#fff;font-size:.72rem;font-weight:700;padding:4px 12px;border-radius:100px;letter-spacing:.06em;text-transform:uppercase">This Week's Feature</span>
        </div>
      </div>
      <div style="padding:40px 36px;display:flex;flex-direction:column;justify-content:center;">
        <span style="font-size:.75rem;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px"><%= featured.category %> &bull; <%= featured.date %></span>
        <h2 style="font-size:1.45rem;font-weight:800;color:var(--navy);line-height:1.35;margin-bottom:14px"><%= featured.title %></h2>
        <p style="color:var(--gray);line-height:1.75;font-size:.92rem;margin-bottom:20px"><%= featured.excerpt %></p>
        <a href="/blog/<%= featured.slug %>" class="btn btn-gold btn-sm" style="align-self:flex-start">Read Article &rarr;</a>
      </div>
    </div>

    <!-- ALL POSTS GRID -->
    <h2 style="font-size:1.2rem;font-weight:700;color:var(--navy);margin-bottom:24px">All Articles</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px;margin-bottom:56px">
      <% posts.forEach(function(post) { %>
      <article style="background:#fff;border:1px solid var(--border);border-radius:10px;overflow:hidden;transition:box-shadow .2s;" onmouseover="this.style.boxShadow='0 4px 18px rgba(0,0,0,0.10)'" onmouseout="this.style.boxShadow=''">
        <div style="background:var(--light);padding:24px 24px 16px">
          <span style="font-size:.72rem;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.07em"><%= post.category %></span>
          <h3 style="font-size:1rem;font-weight:700;color:var(--navy);line-height:1.4;margin:8px 0 10px"><a href="/blog/<%= post.slug %>" style="text-decoration:none;color:inherit"><%= post.title %></a></h3>
          <p style="font-size:.83rem;color:var(--gray);line-height:1.65;margin:0"><%= post.excerpt %></p>
        </div>
        <div style="padding:14px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--border)">
          <span style="font-size:.75rem;color:#9CA3AF"><%= post.date %> &bull; <%= post.read %> read</span>
          <a href="/blog/<%= post.slug %>" style="font-size:.8rem;font-weight:700;color:var(--gold);text-decoration:none">Read &rarr;</a>
        </div>
      </article>
      <% }); %>
    </div>

    <!-- SUBSCRIBE CARD -->
    <div style="background:linear-gradient(135deg,var(--navy) 0%,#2d4a6e 100%);border-radius:16px;padding:48px 40px;text-align:center;max-width:620px;margin:0 auto">
      <h2 style="color:#fff;font-size:1.6rem;font-weight:800;margin-bottom:10px">Get Weekly Tips in Your Inbox</h2>
      <p style="color:rgba(255,255,255,.75);line-height:1.7;margin-bottom:28px">No spam. Just practical advice on growing your small business online — delivered every Monday.</p>
      <form id="subscribe-form" style="display:flex;gap:10px;max-width:420px;margin:0 auto" onsubmit="subscribeBlog(event)">
        <input type="email" id="sub-email" placeholder="your@email.com" required style="flex:1;padding:12px 16px;border:none;border-radius:6px;font-size:.9rem">
        <button type="submit" style="background:var(--gold);color:#fff;border:none;border-radius:6px;padding:12px 20px;font-weight:700;font-size:.9rem;cursor:pointer;white-space:nowrap">Subscribe</button>
      </form>
      <p id="sub-msg" style="color:rgba(255,255,255,.85);font-size:.85rem;margin-top:14px;min-height:20px"></p>
    </div>

  </div>
</section>

<script>
async function subscribeBlog(e) {
  e.preventDefault();
  const email = document.getElementById('sub-email').value;
  const msg = document.getElementById('sub-msg');
  msg.textContent = 'Subscribing...';
  try {
    const res = await fetch('/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email })
    });
    const data = await res.json();
    msg.textContent = data.message;
    if (data.ok) document.getElementById('subscribe-form').reset();
  } catch(err) {
    msg.textContent = 'Something went wrong — try again.';
  }
}
</script>

<style>
@media (max-width: 680px) {
  .blog-featured { grid-template-columns: 1fr !important; }
  .blog-featured > div:first-child { min-height: 160px; padding: 28px !important; }
}
</style>

<%- include('partials/footer') %>
