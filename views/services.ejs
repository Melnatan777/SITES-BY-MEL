    <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-bottom:48px">
      <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:28px">
        <h4 style="color:var(--white);margin-bottom:16px;font-size:.95rem">This is right for you if&hellip;</h4>
        <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:10px">
          <li style="color:rgba(255,255,255,0.7);font-size:.88rem;display:flex;gap:10px"><span style="color:var(--gold)">✓</span>You want to update your own site without calling a developer</li>
