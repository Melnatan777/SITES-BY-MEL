<%- include('partials/head', { title: 'Services — Sites by Mel', metaDesc: 'Personalized website templates from $350, done-for-you template launch at $797, or a fully custom build starting at $1,500. Professional websites for small businesses.' }) %>
<%- include('partials/nav', { activePage: 'services' }) %>

<div class="page-header">
  <div class="container">
    <h1>Services</h1>
    <p style="margin-top:8px;opacity:.8;max-width:520px">Whether you want to do it yourself, have it set up for you, or need something built from scratch — there's an option for every stage of your business.</p>
  </div>
</div>

<section class="section">
  <div class="container">

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:28px;max-width:1000px;margin:0 auto 64px">

      <% packages.forEach(function(pkg) { %>
      <div style="background:#fff;border:<%= pkg.is_featured ? '2px solid var(--gold)' : '1px solid var(--border)' %>;border-radius:14px;overflow:hidden;display:flex;flex-direction:column;position:relative">

        <% if (pkg.is_featured) { %>
        <div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:var(--gold);color:#fff;font-size:.7rem;font-weight:800;padding:4px 18px;border-radius:0 0 8px 8px;letter-spacing:.07em;white-space:nowrap">MOST POPULAR</div>
        <% } %>

        <div style="padding:32px 28px 20px;flex:1">
          <p style="font-size:.72rem;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px"><%= pkg.tagline %></p>
          <h2 style="font-size:1.3rem;font-weight:800;color:var(--navy);margin-bottom:6px"><%= pkg.name %></h2>
          <div style="font-size:1.9rem;font-weight:800;color:var(--navy);margin-bottom:16px"><%= pkg.price_display %><% if (pkg.slug === 'diy') { %><small style="font-size:.75rem;font-weight:400;color:var(--gray);display:block;margin-top:2px">one-time purchase</small><% } %><% if (pkg.slug === 'template_launch') { %><small style="font-size:.75rem;font-weight:400;color:var(--gray);display:block;margin-top:2px">one-time — hosting $15/mo after year 1</small><% } %></div>
          <p style="font-size:.88rem;color:var(--gray);line-height:1.75;margin-bottom:20px"><%= pkg.description %></p>

          <ul style="list-style:none;margin-bottom:24px">
            <% pkg.bullets.forEach(function(b) { %>
            <li style="font-size:.85rem;color:<%= pkg.slug === 'diy' ? 'var(--gray)' : 'var(--navy)' %>;padding:5px 0;display:flex;gap:10px;align-items:flex-start;border-bottom:1px solid var(--border)">
              <span style="color:var(--gold);font-weight:700;flex-shrink:0">✓</span><%= b %>
            </li>
            <% }); %>
          </ul>

          <% if (pkg.slug === 'diy') { %>
          <div style="background:#fdf6e3;border-left:3px solid var(--gold);padding:10px 14px;border-radius:0 6px 6px 0;margin-bottom:20px;font-size:.78rem;color:#7d5a00;line-height:1.6">
            Your personalized site is delivered as a ZIP file — upload it to any host (Netlify, Durable, etc.) in minutes. No monthly fees, no lock-in.
          </div>
          <% } %>
        </div>

        <div style="padding:0 28px 28px">
          <a href="<%= pkg.cta_url %>" class="btn <%= pkg.is_featured ? 'btn-gold' : 'btn-navy' %> btn-full"><%= pkg.cta_label %> &rarr;</a>
        </div>
      </div>
      <% }); %>

    </div>

    <!-- COMPARISON NOTE -->
    <div style="max-width:680px;margin:0 auto 64px;text-align:center">
      <h2 style="font-size:1.2rem;font-weight:700;color:var(--navy);margin-bottom:12px">Not sure which is right for you?</h2>
      <p style="color:var(--gray);line-height:1.8;font-size:.95rem">Want a beautiful site without the hassle? The Template Package is Mel's most popular option — pick a design and she does everything. Need your site fully live on a domain with email? Template Launch. Need something built from scratch around your brand? Let's talk.</p>
      <a href="/contact" class="btn btn-outline" style="margin-top:20px;display:inline-block">Ask Mel a Question</a>
    </div>

    <!-- FAQ -->
    <div style="max-width:680px;margin:0 auto">
      <h2 style="font-size:1.2rem;font-weight:700;color:var(--navy);margin-bottom:20px">Common Questions</h2>
      <div style="border-top:1px solid var(--border)">
        <details style="padding:16px 0;border-bottom:1px solid var(--border)">
          <summary style="cursor:pointer;font-weight:600;font-size:.93rem">What's included in the domain with Template Launch?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:.88rem;line-height:1.75">One year of domain registration is included in the $797 price. After year 1, domain renewal is typically $12–15/year. Hosting renews at $15/month after year 1.</p>
        </details>
        <details style="padding:16px 0;border-bottom:1px solid var(--border)">
          <summary style="cursor:pointer;font-weight:600;font-size:.93rem">Do I own my website?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:.88rem;line-height:1.75">Yes — your domain and all website files belong to you. If you ever want to move to another provider, your files are always available. No lock-in.</p>
        </details>
        <details style="padding:16px 0;border-bottom:1px solid var(--border)">
          <summary style="cursor:pointer;font-weight:600;font-size:.93rem">How long does Template Launch take?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:.88rem;line-height:1.75">Most Template Launch projects are live within 3–5 business days after you provide your content (logo, photos, colors, copy).</p>
        </details>
        <details style="padding:16px 0;border-bottom:1px solid var(--border)">
          <summary style="cursor:pointer;font-weight:600;font-size:.93rem">What does a Full Custom Build include?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:.88rem;line-height:1.75">Everything in Template Launch plus a custom-designed site built around your brand, SEO from day one, Google Analytics, and any advanced features you need. Pricing starts at $1,500 and depends on scope — <a href="/quote" style="color:var(--gold)">request a quote</a> to get an exact number.</p>
        </details>
        <details style="padding:16px 0;border-bottom:1px solid var(--border)">
          <summary style="cursor:pointer;font-weight:600;font-size:.93rem">Can I upgrade from the Template Package to Template Launch later?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:.88rem;line-height:1.75">Yes. If you purchased a Template Package and want Mel to get your site fully live on a domain, contact mel@sitesbymel.com — your $350 will be credited toward the Template Launch price.</p>
        </details>
      </div>
    </div>

  </div>
</section>

<!-- CUSTOM CMS SECTION -->
<section class="section" style="background:var(--navy);color:var(--white)">
  <div class="container">
    <div style="max-width:760px;margin:0 auto 48px;text-align:center">
