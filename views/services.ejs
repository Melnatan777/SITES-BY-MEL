<%- include('partials/head', { title: 'Services', metaDesc: 'Done-for-you website setup and custom site builds for small businesses. Starting at $200.' }) %>
<%- include('partials/nav', { activePage: 'services' }) %>

<div class="page-header">
  <h1>Services</h1>
  <p>Whether you want a hands-off setup or a fully custom build, I've got you covered.</p>
</div>

<section class="section">
  <div class="container">
    <div class="pricing-grid" style="max-width:900px;margin:0 auto;">

      <!-- OPTION 1: Template only -->
      <div class="pricing-card">
        <div class="pricing-name">DIY</div>
        <div class="pricing-price">$37<small>–$57</small></div>
        <p class="pricing-desc">Buy a template and customize it yourself. Perfect if you're comfortable editing HTML.</p>
        <ul class="pricing-features">
          <li>Niche-specific HTML/CSS template</li>
          <li>Mobile-responsive layout</li>
          <li>Instant download after purchase</li>
          <li>Customization guide included</li>
          <li>48-hour download link</li>
        </ul>
        <a href="/templates" class="btn btn-navy btn-full">Browse Templates</a>
      </div>

      <!-- OPTION 2: Done-for-you -->
      <div class="pricing-card featured">
        <div class="pricing-name">Done-For-You</div>
        <div class="pricing-price">$200<small> deposit</small></div>
        <p class="pricing-desc">Choose a template, I'll customize it with your info and get it live. You handle nothing technical.</p>
        <ul class="pricing-features">
          <li>Everything in DIY</li>
          <li>Customized with your content</li>
          <li>Your colors, logo &amp; photos</li>
          <li>Domain &amp; hosting setup</li>
          <li>Contact form wired up</li>
          <li>Live within 5–7 business days</li>
          <li>$200 deposit, balance due at delivery</li>
        </ul>
        <a href="#setup-form" class="btn btn-gold btn-full">Get Started — $200 Deposit</a>
      </div>

      <!-- OPTION 3: Custom quote -->
      <div class="pricing-card">
        <div class="pricing-name">Custom Build</div>
        <div class="pricing-price">Quote</div>
        <p class="pricing-desc">Need something beyond a template? I'll design and build a fully custom site from scratch.</p>
        <ul class="pricing-features">
          <li>Fully custom design</li>
          <li>Any features you need</li>
          <li>E-commerce, booking, blog</li>
          <li>Ongoing maintenance available</li>
          <li>Free consultation call</li>
        </ul>
        <a href="/quote" class="btn btn-outline btn-full">Request a Quote</a>
      </div>

    </div>
  </div>
</section>

<!-- CMS BACKEND -->
<section class="section section-navy">
  <div class="container">
    <div style="max-width:800px;margin:0 auto;text-align:center;">
      <span class="hero-badge" style="margin-bottom:20px;display:inline-block;">Premium Service</span>
