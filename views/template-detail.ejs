<%- include('partials/head', { title: product.name, metaDesc: product.description }) %>
<%- include('partials/nav', { activePage: 'templates' }) %>

<% if (locals.query && locals.query.agree === 'required') { %>
<div style="background:#fef2f2;border-bottom:2px solid #fca5a5;padding:14px 24px;text-align:center;font-size:.88rem;color:#991b1b;font-weight:600">
  Please check the agreement box below before proceeding to checkout.
</div>
<% } %>
<div class="page-header" style="text-align:left;padding:36px 24px;">
  <div class="container">
    <p style="font-size:0.85rem;opacity:0.65;margin-bottom:8px;"><a href="/templates" style="color:rgba(255,255,255,0.7);">Templates</a> &rsaquo; <%= product.name %></p>
    <h1 style="margin-bottom:0;"><%= product.name %></h1>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="template-detail-grid">

      <!-- LEFT: Preview + info -->
      <div>
        <div class="template-preview">
          <% if (product.thumbnail) { %>
            <img src="/images/<%= product.thumbnail %>" alt="<%= product.name %> preview" />
          <% } else { %>
            <div class="template-preview-placeholder">
              <span style="font-size:3rem;">🌐</span>
              <span>Preview image coming soon</span>
            </div>
          <% } %>
        </div>

        <div style="margin-top:36px;">
          <h2 style="font-size:1.3rem;margin-bottom:14px;">About This Template</h2>
          <p style="color:var(--gray);line-height:1.8;"><%= product.description %></p>

          <div id="addon-detail-box" style="margin-top:28px;padding:20px;background:var(--light);border-radius:6px;transition:all 0.2s;">
            <h3 id="addon-detail-title" style="font-size:0.95rem;margin-bottom:14px;color:var(--navy);">What's Included</h3>
            <ul id="addon-detail-list" style="list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:8px;">
              <li style="font-size:0.88rem;color:var(--gray);">✓ Full HTML source files</li>
              <li style="font-size:0.88rem;color:var(--gray);">✓ CSS stylesheet</li>
              <li style="font-size:0.88rem;color:var(--gray);">✓ Mobile-responsive layout</li>
              <li style="font-size:0.88rem;color:var(--gray);">✓ Customization guide</li>
              <li style="font-size:0.88rem;color:var(--gray);">✓ Contact form ready</li>
              <li style="font-size:0.88rem;color:var(--gray);">✓ Lifetime download access</li>
            </ul>
          </div>

          <div style="margin-top:28px;">
            <h3 style="font-size:0.95rem;margin-bottom:14px;">Built For</h3>
            <span style="background:var(--navy);color:var(--white);padding:6px 16px;border-radius:100px;font-size:0.82rem;"><%= product.category %></span>
          </div>
        </div>
      </div>

      <!-- RIGHT: Price card -->
      <div>
        <div class="price-card">
          <div class="price">$<%= (product.price / 100).toFixed(0) %></div>
          <p class="price-note">One-time purchase &mdash; yours to keep forever</p>

          <% if (product.active) { %>

            <!-- WHAT'S INCLUDED -->
            <div style="margin-bottom:20px;padding:16px;background:#f8f6f2;border-radius:8px;">
              <p style="font-size:0.78rem;font-weight:700;color:var(--navy);margin-bottom:10px;text-transform:uppercase;letter-spacing:.05em;">What's Included</p>
              <ul style="list-style:none;margin:0;padding:0;display:grid;grid-template-columns:1fr 1fr;gap:7px;">
                <li style="font-size:0.82rem;color:var(--gray);">✓ Personalized by Mel</li>
                <li style="font-size:0.82rem;color:var(--gray);">✓ Your text & business info</li>
                <li style="font-size:0.82rem;color:var(--gray);">✓ Your photos added in</li>
                <li style="font-size:0.82rem;color:var(--gray);">✓ Mobile-responsive layout</li>
                <li style="font-size:0.82rem;color:var(--gray);">✓ Contact form ready</li>
                <li style="font-size:0.82rem;color:var(--gray);">✓ Ready to go live free</li>
              </ul>
            </div>

            <!-- COUPON CODE -->
            <div style="margin-bottom:12px">
              <div style="display:flex;gap:8px">
                <input type="text" id="coupon-input" placeholder="Have a coupon code?" maxlength="30"
                  style="flex:1;padding:9px 12px;border:1px solid var(--border);border-radius:6px;font-size:.85rem;text-transform:uppercase;font-family:monospace;letter-spacing:.05em">
                <button type="button" onclick="applyCoupon()" style="padding:9px 14px;background:var(--light);border:1px solid var(--border);border-radius:6px;font-size:.82rem;font-weight:700;color:var(--navy);cursor:pointer;white-space:nowrap">Apply</button>
              </div>
              <div id="coupon-msg" style="font-size:.75rem;margin-top:5px;display:none"></div>
            </div>

            <form action="/buy/<%= product.slug %>" method="POST" id="buy-form">
              <input type="hidden" name="selected_addon" value="none">
              <input type="hidden" name="coupon_code" id="coupon-code-input" value="">
              <div style="background:#fefce8;border:1px solid #fde68a;border-radius:8px;padding:12px 14px;margin-bottom:12px;display:flex;align-items:flex-start;gap:10px">
                <input type="checkbox" name="agreed_to_terms" value="yes" required id="agree-checkbox" style="margin-top:3px;width:15px;height:15px;flex-shrink:0;accent-color:#C9922B;cursor:pointer">
                <label for="agree-checkbox" style="font-size:.78rem;color:#374151;line-height:1.6;cursor:pointer">I have read and agree to the <a href="/agreement" target="_blank" style="color:#C9922B;font-weight:700;text-decoration:underline">Sites by Mel Website Design Agreement</a>. I understand that work begins after checkout and refunds are not available once work has started.</label>
              </div>
              <button type="submit" id="buy-btn" class="btn btn-gold btn-full" style="font-size:1rem;padding:14px;">
                Get My Website — $<%= (product.price / 100).toFixed(0) %> &rarr;
              </button>
            </form>
            <p style="font-size:0.78rem;color:var(--gray);text-align:center;margin-top:10px;">Secure checkout via Stripe. Your personalized site delivered within 48 hours.</p>
          <% } else { %>
            <button class="btn btn-full" style="background:var(--border);color:var(--gray);cursor:default;padding:14px;font-size:1rem;">Coming Soon</button>
          <% } %>

          <script>
            var activeCoupon = null;
            var basePrice = <%= product.price / 100 %>;

            function applyCoupon() {
              var code = document.getElementById('coupon-input').value.trim();
              var msg = document.getElementById('coupon-msg');
              if (!code) { msg.style.display='none'; return; }
              msg.style.display = 'block';
              msg.style.color = '#6B7280';
              msg.textContent = 'Checking...';
              fetch('/coupon/validate?code=' + encodeURIComponent(code) + '&slug=<%= product.slug %>')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                  if (data.valid) {
                    activeCoupon = data;
                    document.getElementById('coupon-code-input').value = code;
                    var disc = data.type === 'percent'
                      ? Math.round(basePrice * data.value / 100)
                      : Math.min(data.value, basePrice - 1);
                    var final = basePrice - disc;
                    msg.style.color = '#166534';
                    msg.textContent = '✓ Coupon applied' + (data.description ? ' — ' + data.description : '') + '!';
                    document.getElementById('buy-btn').textContent = 'Get My Website — $' + final + ' (save $' + disc + ') →';
                  } else {
                    activeCoupon = null;
                    document.getElementById('coupon-code-input').value = '';
                    msg.style.color = '#991b1b';
                    msg.textContent = '✗ ' + data.message;
                    document.getElementById('buy-btn').textContent = 'Get My Website — $' + basePrice + ' →';
                  }
                });
            }
            document.getElementById('coupon-input').addEventListener('keydown', function(e) {
              if (e.key === 'Enter') { e.preventDefault(); applyCoupon(); }
            });
          </script>

          <% if (product.preview_url) { %>
            <a href="<%= product.preview_url %>" target="_blank" rel="noopener" class="btn btn-outline btn-full" style="margin-top:12px;text-align:center;">
              View Live Preview &rarr;
            </a>
          <% } %>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <div style="margin-top:56px;max-width:680px;">
      <h2 style="font-size:1.3rem;margin-bottom:24px;">Frequently Asked Questions</h2>
      <div style="border-top:1px solid var(--border);">
        <details style="padding:16px 0;border-bottom:1px solid var(--border);">
          <summary style="cursor:pointer;font-weight:600;font-size:0.95rem;">How do I get my files after purchase?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:0.9rem;">After checkout, you'll be redirected to a confirmation page with your download link. The same link is also emailed to you immediately. It's valid for 48 hours.</p>
        </details>
        <details style="padding:16px 0;border-bottom:1px solid var(--border);">
          <summary style="cursor:pointer;font-weight:600;font-size:0.95rem;">Can I edit the template myself?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:0.9rem;">Yes. The files are plain HTML and CSS — open in any text editor and swap out text, colors, and images. No coding experience required for basic changes.</p>
        </details>
        <details style="padding:16px 0;border-bottom:1px solid var(--border);">
          <summary style="cursor:pointer;font-weight:600;font-size:0.95rem;">What if I need help setting it up?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:0.9rem;">That's what the <a href="/services">Done-For-You Setup</a> is for. I'll customize the template with your content and get it live on your domain for a $200 deposit.</p>
        </details>
        <details style="padding:16px 0;border-bottom:1px solid var(--border);">
          <summary style="cursor:pointer;font-weight:600;font-size:0.95rem;">Can I use this template for multiple sites?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:0.9rem;">Each purchase is licensed for one website. If you need it on multiple sites, purchase one copy per site or <a href="/contact">contact me</a> about a multi-license deal.</p>
        </details>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
