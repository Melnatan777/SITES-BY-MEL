<%- include('partials/head', { title: product.name, metaDesc: product.description }) %>
<%- include('partials/nav', { activePage: 'templates' }) %>

<div class="page-header" style="text-align:left;padding:36px 24px;">
  <div class="container">
    <p style="font-size:0.85rem;opacity:0.65;margin-bottom:8px;"><a href="/templates" style="color:rgba(255,255,255,0.7);">Templates</a> &rsaquo; <%= product.name %></p>
    <h1 style="margin-bottom:0;"><%= product.name %></h1>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="template-detail-grid">

      <!-- LEFT: Preview + info -->
      <div>
        <div class="template-preview">
          <% if (product.thumbnail) { %>
            <img src="/images/<%= product.thumbnail %>" alt="<%= product.name %> preview" />
          <% } else { %>
            <div class="template-preview-placeholder">
              <span style="font-size:3rem;">🌐</span>
              <span>Preview image coming soon</span>
            </div>
          <% } %>
        </div>

        <div style="margin-top:36px;">
          <h2 style="font-size:1.3rem;margin-bottom:14px;">About This Template</h2>
          <p style="color:var(--gray);line-height:1.8;"><%= product.description %></p>

          <div id="addon-detail-box" style="margin-top:28px;padding:20px;background:var(--light);border-radius:6px;transition:all 0.2s;">
            <h3 id="addon-detail-title" style="font-size:0.95rem;margin-bottom:14px;color:var(--navy);">What's Included</h3>
            <ul id="addon-detail-list" style="list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:8px;">
              <li style="font-size:0.88rem;color:var(--gray);">✓ Full HTML source files</li>
              <li style="font-size:0.88rem;color:var(--gray);">✓ CSS stylesheet</li>
              <li style="font-size:0.88rem;color:var(--gray);">✓ Mobile-responsive layout</li>
              <li style="font-size:0.88rem;color:var(--gray);">✓ Customization guide</li>
              <li style="font-size:0.88rem;color:var(--gray);">✓ Contact form ready</li>
              <li style="font-size:0.88rem;color:var(--gray);">✓ Lifetime download access</li>
            </ul>
          </div>

          <div style="margin-top:28px;">
            <h3 style="font-size:0.95rem;margin-bottom:14px;">Built For</h3>
            <span style="background:var(--navy);color:var(--white);padding:6px 16px;border-radius:100px;font-size:0.82rem;"><%= product.category %></span>
          </div>
        </div>
      </div>

      <!-- RIGHT: Price card -->
      <div>
        <div class="price-card">
          <div class="price">$<%= (product.price / 100).toFixed(0) %></div>
          <p class="price-note">One-time purchase &mdash; yours to keep forever</p>

          <% if (product.active) { %>

            <!-- ADD-ON OPTIONS -->
            <div style="margin-bottom:16px;">
              <p style="font-size:0.8rem;font-weight:700;color:var(--navy);margin-bottom:10px;text-transform:uppercase;letter-spacing:.05em;">Optional Add-Ons</p>

              <div id="opt-none" onclick="selectOption('none')" style="border:2px solid var(--gold);border-radius:8px;padding:12px 14px;margin-bottom:8px;cursor:pointer;background:#fffdf7;">
                <div style="display:flex;justify-content:space-between;align-items:center;">
                  <div>
                    <span style="font-size:0.88rem;font-weight:700;color:var(--navy);">&#10003; Template Only</span>
                    <span style="font-size:0.75rem;color:var(--gray);display:block;margin-top:2px;">I'll customize it myself</span>
                  </div>
                  <span style="font-weight:800;color:var(--gold);font-size:1rem;">$197</span>
                </div>
              </div>

              <div id="opt-upload" onclick="selectOption('upload')" style="border:2px solid var(--border);border-radius:8px;padding:12px 14px;margin-bottom:8px;cursor:pointer;">
                <div style="display:flex;justify-content:space-between;align-items:center;">
                  <div>
                    <span style="font-size:0.88rem;font-weight:700;color:var(--navy);">+ Photo Swap</span>
                    <span style="font-size:0.75rem;color:var(--gray);display:block;margin-top:2px;">Upload up to 5 photos — Mel embeds them into your template within 2 days <em>(total $294)</em></span>
                  </div>
                  <span style="font-weight:800;color:var(--gold);font-size:1rem;">+$97</span>
                </div>
              </div>

              <div id="opt-colors" onclick="selectOption('colors')" style="border:2px solid var(--border);border-radius:8px;padding:12px 14px;margin-bottom:8px;cursor:pointer;">
                <div style="display:flex;justify-content:space-between;align-items:center;">
                  <div>
                    <span style="font-size:0.88rem;font-weight:700;color:var(--navy);">+ Custom Brand Colors</span>
                    <span style="font-size:0.75rem;color:var(--gray);display:block;margin-top:2px;">Tell Mel your colors — she swaps every button, heading &amp; accent to match your brand <em>(total $294)</em></span>
                  </div>
                  <span style="font-weight:800;color:var(--gold);font-size:1rem;">+$97</span>
                </div>
              </div>

              <div id="opt-payment" onclick="selectOption('payment')" style="border:2px solid var(--border);border-radius:8px;padding:12px 14px;margin-bottom:8px;cursor:pointer;">
                <div style="display:flex;justify-content:space-between;align-items:center;">
                  <div>
                    <span style="font-size:0.88rem;font-weight:700;color:var(--navy);">+ Payment Button &amp; Business Email Setup</span>
                    <span style="font-size:0.75rem;color:var(--gray);display:block;margin-top:2px;">Stripe payment button + your professional business email (you@yourdomain.com) <em>(total $394)</em></span>
                  </div>
                  <span style="font-weight:800;color:var(--gold);font-size:1rem;">+$197</span>
                </div>
              </div>

              <div id="opt-glove" onclick="selectOption('glove')" style="border:2px solid var(--border);border-radius:8px;padding:12px 14px;margin-bottom:8px;cursor:pointer;">
                <div style="display:flex;justify-content:space-between;align-items:center;">
                  <div>
                    <span style="font-size:0.88rem;font-weight:700;color:var(--navy);">+ White-Glove Template <span style="background:#fdf0ed;color:#c0392b;font-size:.68rem;font-weight:700;padding:1px 7px;border-radius:100px;margin-left:4px;">Best Value</span></span>
                    <span style="font-size:0.75rem;color:var(--gray);display:block;margin-top:2px;">Photos + brand colors + text tweaks + final review — nearly done for you <em>(total $597)</em></span>
                  </div>
                  <span style="font-weight:800;color:var(--gold);font-size:1rem;">+$400</span>
                </div>
              </div>
            </div>

            <form action="/buy/<%= product.slug %>" method="POST" id="buy-form">
              <input type="hidden" name="selected_addon" id="selected-addon-input" value="none">
              <button type="submit" id="buy-btn" class="btn btn-gold btn-full" style="font-size:1rem;padding:14px;">
                Buy &amp; Download — $197 &rarr;
              </button>
            </form>
            <p style="font-size:0.78rem;color:var(--gray);text-align:center;margin-top:10px;">Secure checkout via Stripe. Taxes calculated at checkout. Klarna buy-now-pay-later may be available at checkout.</p>

            <div style="margin-top:14px;padding:12px 14px;background:#fdf6e3;border-radius:6px;border-left:3px solid #C9922B;">
              <p style="font-size:0.75rem;color:#7d5a00;line-height:1.6;margin:0;">
                <strong>This is a DIY template.</strong> It's built for small business owners who are comfortable on a computer — someone who can open a file, edit text, and follow written instructions — no coding skills needed. Full step-by-step instructions are included. If you'd rather hand it off, the <a href="/services" style="color:#C9922B;font-weight:600;">Done-For-You Setup</a> has you covered.
              </p>
            </div>
          <% } else { %>
            <button class="btn btn-full" style="background:var(--border);color:var(--gray);cursor:default;padding:14px;font-size:1rem;">Coming Soon</button>
          <% } %>

          <script>
            const prices = { none: 197, upload: 294, colors: 294, payment: 394, glove: 597 };
            const labels = { none: 'Buy & Download — $197', upload: 'Buy Now — $294 total', colors: 'Buy Now — $294 total', payment: 'Buy Now — $394 total', glove: 'Buy Now — $597 total' };

            const addonDetails = {
              none: {
                title: "What's Included",
                items: [
                  '✓ Full HTML source files', '✓ CSS stylesheet',
                  '✓ Mobile-responsive layout', '✓ Customization guide',
                  '✓ Contact form ready', '✓ Lifetime download access'
                ]
              },
              drive: {
                title: '+ Photo Swap — What Mel Does For You',
                items: [
                  '✓ Everything in template', '✓ You share a Google Drive link',
                  '✓ Mel swaps in your photos', '✓ Returned within 2 business days',
                  '✓ Up to 5 photos placed', '✓ No back-and-forth needed'
                ]
              },
              upload: {
                title: '+ Direct Photo Upload — What Mel Does For You',
                items: [
                  '✓ Everything in template', '✓ Upload your photos directly',
                  '✓ Mel embeds them on your pages', '✓ Returned within 2 business days',
                  '✓ Up to 5 photos placed', '✓ Properly sized & optimized'
                ]
              },
              glove: {
                title: '+ White-Glove Finish — What Mel Does For You',
                items: [
                  '✓ Everything in template', '✓ Your photos swapped in',
                  '✓ Text updated with your details', '✓ Colors adjusted to your brand',
                  '✓ Full review & polish', '✓ Nearly ready to go live'
                ]
              },
              colors: {
                title: '+ Custom Brand Colors — What Mel Does For You',
                items: [
                  '✓ Everything in template', '✓ You tell Mel your brand colors',
                  '✓ Every button & accent updated', '✓ Headings & highlights matched',
                  '✓ Returned within 2 business days', '✓ Looks like YOUR brand, not a template'
                ]
              },
              payment: {
                title: '+ Payment & Email Setup — What Mel Does For You',
                items: [
                  '✓ Everything in template', '✓ Stripe payment button built & tested',
                  '✓ Professional email set up (you@yourdomain.com)', '✓ Email forwarding to your inbox',
                  '✓ Both embedded & working', '✓ Look like a legit business from day one'
                ]
              }
            };

            function selectOption(key) {
              ['none','upload','colors','payment','glove'].forEach(function(k) {
                var el = document.getElementById('opt-' + k);
                if (el) el.style.borderColor = k === key ? 'var(--gold)' : 'var(--border)';
                if (el) el.style.background = k === key ? '#fffdf7' : '';
              });
              document.getElementById('selected-addon-input').value = key;
              document.getElementById('buy-btn').textContent = labels[key] + ' →';

              // Update left panel
              var detail = addonDetails[key];
              document.getElementById('addon-detail-title').textContent = detail.title;
              var list = document.getElementById('addon-detail-list');
              list.style.gridTemplateColumns = '1fr 1fr';
              list.innerHTML = detail.items.map(function(i) {
                return '<li style="font-size:0.88rem;color:var(--gray);">' + i + '</li>';
              }).join('');
              document.getElementById('addon-detail-box').style.background = key === 'none' ? 'var(--light)' : '#f0f7ff';
            }
          </script>

          <% if (product.preview_url) { %>
            <a href="<%= product.preview_url %>" target="_blank" rel="noopener" class="btn btn-outline btn-full" style="margin-top:12px;text-align:center;">
              View Live Preview &rarr;
            </a>
          <% } %>

          <ul class="price-includes" style="margin-top:24px;">
            <li>HTML + CSS source files</li>
            <li>Mobile-responsive design</li>
            <li>No subscription fees</li>
            <li>48-hour download link</li>
            <li>Customization tips included</li>
          </ul>

          <div style="border-top:1px solid var(--border);padding-top:20px;margin-top:4px;">
            <p style="font-size:0.85rem;color:var(--gray);margin-bottom:12px;">Need it set up for you?</p>
            <a href="/services#setup-<%= product.slug %>" class="btn btn-outline btn-sm btn-full">Done-For-You Setup — $200 deposit</a>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <div style="margin-top:56px;max-width:680px;">
      <h2 style="font-size:1.3rem;margin-bottom:24px;">Frequently Asked Questions</h2>
      <div style="border-top:1px solid var(--border);">
        <details style="padding:16px 0;border-bottom:1px solid var(--border);">
          <summary style="cursor:pointer;font-weight:600;font-size:0.95rem;">How do I get my files after purchase?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:0.9rem;">After checkout, you'll be redirected to a confirmation page with your download link. The same link is also emailed to you immediately. It's valid for 48 hours.</p>
        </details>
        <details style="padding:16px 0;border-bottom:1px solid var(--border);">
          <summary style="cursor:pointer;font-weight:600;font-size:0.95rem;">Can I edit the template myself?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:0.9rem;">Yes. The files are plain HTML and CSS — open in any text editor and swap out text, colors, and images. No coding experience required for basic changes.</p>
        </details>
        <details style="padding:16px 0;border-bottom:1px solid var(--border);">
          <summary style="cursor:pointer;font-weight:600;font-size:0.95rem;">What if I need help setting it up?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:0.9rem;">That's what the <a href="/services">Done-For-You Setup</a> is for. I'll customize the template with your content and get it live on your domain for a $200 deposit.</p>
        </details>
        <details style="padding:16px 0;border-bottom:1px solid var(--border);">
          <summary style="cursor:pointer;font-weight:600;font-size:0.95rem;">Can I use this template for multiple sites?</summary>
          <p style="margin-top:10px;color:var(--gray);font-size:0.9rem;">Each purchase is licensed for one website. If you need it on multiple sites, purchase one copy per site or <a href="/contact">contact me</a> about a multi-license deal.</p>
        </details>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
