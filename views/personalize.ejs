<%- include('partials/head', { title: 'Personalize Your Template — Sites by Mel', metaDesc: 'Enter your business details and we will pre-fill your website template for you.' }) %>
<%- include('partials/nav') %>

<section style="padding:60px 0 80px;background:#F4F2EE;min-height:80vh">
  <div style="max-width:660px;margin:0 auto;padding:0 24px">

    <div style="text-align:center;margin-bottom:32px">
      <h1 style="font-size:1.8rem;font-weight:800;color:#1B2F4E;margin-bottom:8px">Personalize Your Template</h1>
      <p style="color:#6B7280;line-height:1.7;max-width:480px;margin:0 auto">Fill in your business details and we will pre-fill your site before you download. Add optional services below — you will see the full price before paying anything extra.</p>
    </div>

    <form method="POST" action="/personalize/<%= token %>" enctype="multipart/form-data">

      <!-- BUSINESS DETAILS -->
      <div style="background:#fff;border:1px solid #E5E0D8;border-radius:12px;padding:28px;margin-bottom:16px">
        <h2 style="font-size:1rem;font-weight:700;color:#1B2F4E;margin-bottom:18px">Your Business Details</h2>
        <div style="background:#F4F2EE;border-radius:8px;padding:10px 14px;margin-bottom:18px;font-size:.82rem;color:#374151">
          Template: <strong><%= product.name %></strong> &nbsp;&bull;&nbsp; All fields optional — skip what you don't have yet.
        </div>

        <div style="margin-bottom:14px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Business Name</label>
          <input type="text" name="businessName" placeholder="<%= placeholder.businessName %>" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Replaces "<%= placeholder.businessName %>" everywhere in your file</p>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Phone Number</label>
            <input type="tel" name="phone" placeholder="<%= placeholder.phone || '(555) 000-0000' %>" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Business Email</label>
            <input type="email" name="email" placeholder="<%= placeholder.email %>" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem">
          </div>
        </div>

        <div style="margin-bottom:14px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Address / City</label>
          <input type="text" name="address" placeholder="<%= placeholder.address || 'Your City, State' %>" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem">
        </div>

        <div>
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Tagline / Slogan <span style="font-weight:400;color:#9CA3AF">(optional)</span></label>
          <input type="text" name="tagline" placeholder="<%= placeholder.tagline %>" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem">
        </div>
      </div>

      <!-- ADD-ON SPECIFIC FIELDS -->
      <% if (selectedAddon === 'drive') { %>
      <div style="background:#fff;border:2px solid #C9922B;border-radius:12px;padding:28px;margin-bottom:16px">
        <h2 style="font-size:1rem;font-weight:700;color:#1B2F4E;margin-bottom:6px">📸 Photo Swap — Paste Your Google Drive Link</h2>
        <p style="font-size:.82rem;color:#6B7280;margin-bottom:16px">Put your photos in a Google Drive folder and share the link below. Mel will swap them into your template and email you the finished version within 2 business days.</p>

        <div style="background:#fdf6e3;border-left:3px solid #C9922B;padding:12px 16px;border-radius:0 6px 6px 0;margin-bottom:16px;font-size:.82rem;color:#7d5a00">
          <strong>How to share your Google Drive folder:</strong>
          <ol style="margin:8px 0 0 16px;line-height:2">
            <li>Go to <strong>drive.google.com</strong> and open (or create) a folder with your photos</li>
            <li>Right-click the folder → click <strong>"Share"</strong></li>
            <li>Click <strong>"Change to anyone with the link"</strong> — this lets Mel open it without needing a Google account invite</li>
            <li>Make sure it says <strong>"Viewer"</strong> (not Editor) — then click <strong>"Copy link"</strong></li>
            <li>Paste that link in the box below</li>
          </ol>
        </div>

        <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Your Google Drive Link <span style="color:#C9922B">*</span></label>
        <input type="url" name="drive_link" placeholder="https://drive.google.com/drive/folders/..." style="width:100%;padding:10px 14px;border:1px solid #C9922B;border-radius:6px;font-size:.9rem" required>
        <p style="font-size:.72rem;color:#9CA3AF;margin-top:4px">The link should start with https://drive.google.com — if you can open it in a private browser window without signing in, it's set correctly.</p>
      </div>
      <% } else if (selectedAddon === 'upload') { %>
      <div style="background:#fff;border:2px solid #C9922B;border-radius:12px;padding:28px;margin-bottom:16px">
        <h2 style="font-size:1rem;font-weight:700;color:#1B2F4E;margin-bottom:6px">📤 Direct Photo Upload — Upload Your Photos</h2>
        <p style="font-size:.82rem;color:#6B7280;margin-bottom:16px">Upload your photos below. Mel will embed them into your template and email you the finished version within 2 business days.</p>

        <div style="background:#fdf6e3;border-left:3px solid #C9922B;padding:12px 16px;border-radius:0 6px 6px 0;margin-bottom:16px;font-size:.82rem;color:#7d5a00">
          <strong>Tips for best results:</strong>
          <ul style="margin:8px 0 0 16px;line-height:2">
            <li>Use <strong>clear, well-lit photos</strong> — natural light works best</li>
            <li>Landscape (horizontal) photos work better than portrait (vertical) for website headers</li>
            <li>Photos from your phone camera are perfectly fine</li>
            <li>You can upload up to <strong>5 photos</strong></li>
          </ul>
        </div>

        <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Upload Your Photos (up to 5) <span style="color:#C9922B">*</span></label>
        <input type="file" name="photos" accept="image/*" multiple style="width:100%;padding:10px 14px;border:1px solid #C9922B;border-radius:6px;font-size:.85rem;background:#fff">
        <p style="font-size:.72rem;color:#9CA3AF;margin-top:4px">JPG, PNG, or WEBP accepted. Hold Ctrl (Windows) or Cmd (Mac) while clicking to select multiple photos at once.</p>
      </div>
      <% } else if (selectedAddon === 'colors') { %>
      <div style="background:#fff;border:2px solid #C9922B;border-radius:12px;padding:28px;margin-bottom:16px">
        <h2 style="font-size:1rem;font-weight:700;color:#1B2F4E;margin-bottom:6px">🎨 Custom Brand Colors</h2>
        <p style="font-size:.82rem;color:#6B7280;margin-bottom:14px">Share your brand colors and Mel will update the entire template to match. If you don't know your hex codes, describe the colors and she'll match them.</p>
        <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Your Brand Colors</label>
        <input type="text" name="brand_colors" placeholder="e.g. Navy blue #1a2a5c and gold #e8a020 — or describe: deep teal and warm orange" style="width:100%;padding:10px 14px;border:1px solid #C9922B;border-radius:6px;font-size:.9rem">
      </div>
      <% } else if (selectedAddon === 'glove') { %>
      <div style="background:#fff;border:2px solid #C9922B;border-radius:12px;padding:28px;margin-bottom:16px">
        <h2 style="font-size:1rem;font-weight:700;color:#1B2F4E;margin-bottom:6px">✨ White-Glove Finish</h2>
        <p style="font-size:.82rem;color:#6B7280;margin-bottom:0">Mel will reach out to your email within 1 business day to get started on your full customization. Make sure your business email above is correct!</p>
      </div>
      <% } else if (selectedAddon === 'payment') { %>
      <div style="background:#fff;border:2px solid #C9922B;border-radius:12px;padding:28px;margin-bottom:16px">
        <h2 style="font-size:1rem;font-weight:700;color:#1B2F4E;margin-bottom:6px">💳 Payment Button & Business Email Setup</h2>
        <p style="font-size:.82rem;color:#6B7280;margin-bottom:0">Mel will reach out to your email within 1 business day to set up your payment button and business email. Make sure your email above is correct!</p>
      </div>
      <% } %>

      <!-- WHAT HAPPENS NEXT -->
      <div style="background:#f0f7ff;border:1px solid #bfdbfe;border-radius:12px;padding:20px 24px;margin-bottom:16px">
        <p style="font-size:.85rem;color:#1e40af;line-height:1.7;margin:0">
          <strong>What happens next:</strong> Your template download will start immediately.<% if (selectedAddon && selectedAddon !== 'none') { %> Mel will follow up within 1–2 business days to complete your <strong><%= {drive:'Photo Swap',upload:'Photo Upload',colors:'Brand Colors',glove:'White-Glove',payment:'Payment Setup'}[selectedAddon] || 'add-on' %></strong>.<% } %>
        </p>
      </div>

      <button type="submit" style="width:100%;background:#C9922B;color:#fff;padding:14px;border:none;border-radius:8px;font-size:1rem;font-weight:700;cursor:pointer">
        Download My Template &rarr;
      </button>
      <p style="text-align:center;font-size:.75rem;color:#9CA3AF;margin-top:8px">All fields above are optional — fill in what you have, skip the rest.</p>

      <div style="text-align:center;margin-top:14px">
        <a href="/download/<%= token %>" style="font-size:.8rem;color:#9CA3AF;text-decoration:none">Skip personalization — download generic version</a>
      </div>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
