<%- include('partials/head', { title: 'Personalize Your Template — Sites by Mel', metaDesc: 'Enter your business details and we will pre-fill your website template for you.' }) %>
<%- include('partials/nav') %>

<section style="padding:60px 0 80px;background:#F4F2EE;min-height:80vh">
  <div style="max-width:620px;margin:0 auto;padding:0 24px">

    <div style="text-align:center;margin-bottom:36px">
      <div style="display:inline-flex;align-items:center;justify-content:center;width:56px;height:56px;background:#1B2F4E;border-radius:50%;margin-bottom:16px">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#C9922B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      </div>
      <h1 style="font-size:1.8rem;font-weight:800;color:#1B2F4E;margin-bottom:8px">One last step</h1>
      <p style="color:#6B7280;line-height:1.7;max-width:480px;margin:0 auto">Enter your business details below and I will pre-fill your website with your real information before you download. The less you have to change, the better.</p>
    </div>

    <div style="background:#fff;border:1px solid #E5E0D8;border-radius:12px;padding:32px">
      <div style="background:#F4F2EE;border-radius:8px;padding:12px 16px;margin-bottom:24px;font-size:.85rem;color:#374151">
        <strong>Template:</strong> <%= product.name %> &nbsp;&bull;&nbsp; <strong>All fields are optional</strong> — skip any you don't have yet.
      </div>

      <form method="POST" action="/personalize/<%= token %>">

        <div style="margin-bottom:16px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:6px;color:#374151">Business Name</label>
          <input type="text" name="businessName" placeholder="<%= placeholder.businessName %>" style="width:100%;padding:11px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.92rem">
          <p style="font-size:.74rem;color:#9CA3AF;margin-top:4px">We'll replace "<%= placeholder.businessName %>" with yours everywhere in the file.</p>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:6px;color:#374151">Phone Number</label>
            <input type="tel" name="phone" placeholder="<%= placeholder.phone || '(555) 000-0000' %>" style="width:100%;padding:11px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.92rem">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:6px;color:#374151">Business Email</label>
            <input type="email" name="email" placeholder="<%= placeholder.email %>" style="width:100%;padding:11px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.92rem">
          </div>
        </div>

        <div style="margin-bottom:16px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:6px;color:#374151">Address / City</label>
          <input type="text" name="address" placeholder="<%= placeholder.address || 'Your City, State' %>" style="width:100%;padding:11px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.92rem">
        </div>

        <div style="margin-bottom:24px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:6px;color:#374151">Tagline / Slogan <span style="font-weight:400;color:#9CA3AF">(optional)</span></label>
          <input type="text" name="tagline" placeholder="<%= placeholder.tagline %>" style="width:100%;padding:11px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.92rem">
          <p style="font-size:.74rem;color:#9CA3AF;margin-top:4px">A short phrase that describes what you do. Can change it later.</p>
        </div>

        <button type="submit" style="width:100%;background:#1B2F4E;color:#fff;padding:14px;border:none;border-radius:8px;font-size:1rem;font-weight:700;cursor:pointer">
          Build My Personalized Download &rarr;
        </button>
        <p style="text-align:center;font-size:.78rem;color:#9CA3AF;margin-top:10px">Your zip file will generate and download automatically.</p>
      </form>

      <div style="border-top:1px solid #E5E0D8;margin-top:20px;padding-top:16px;text-align:center">
        <a href="/download/<%= token %>" style="font-size:.82rem;color:#9CA3AF;text-decoration:none">Skip this step — download the generic version instead</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
