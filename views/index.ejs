<!-- TEMPLATES -->
<section class="section" style="background:var(--cream)">
  <div class="container">
    <div class="section-header">
      <div class="section-tag">Template Shop</div>
      <h2>Ready-to-use website templates</h2>
      <p>Hand-coded HTML/CSS templates for real businesses. Download, customize with your info, and go live. No coding experience needed.</p>
    </div>
    <%
    var colorMap = {
      'service-pro': { bg: 't-blue',   cat: 't-cat-blue',   btn: '#F59E0B' },
      'table-ready': { bg: 't-red',    cat: 't-cat-red',    btn: '#D4A227' },
      'key-ready':   { bg: 't-green',  cat: 't-cat-green',  btn: '#10B981' },
      'shop-front':  { bg: 't-brown',  cat: 't-cat-brown',  btn: '#F59E0B' },
      'voice-first': { bg: 't-teal',   cat: 't-cat-teal',   btn: '#06B6D4' },
      'gather-here': { bg: 't-purple', cat: 't-cat-purple', btn: '#D4A227' },
    };
    %>
    <div class="templates-grid-new">
      <% products.forEach(function(p) {
        var c = colorMap[p.slug] || { bg: 't-blue', cat: 't-cat-blue', btn: '#F59E0B' };
      %>
      <div class="template-card-new">
        <div class="template-preview-area <%= c.bg %>">
          <div class="tp-nav"></div>
          <div class="tp-h"></div>
          <div class="tp-sub"></div>
          <div class="tp-btn" style="background:<%= c.btn %>"></div>
          <% if (p.active) { %>
            <div class="template-available-badge">Available Now</div>
          <% } else { %>
            <div class="template-soon-badge">Coming Soon</div>
          <% } %>
        </div>
        <div class="template-card-body">
          <div class="template-cat-tag <%= c.cat %>"><%= p.category %></div>
          <h3><%= p.name %></h3>
          <p><%= p.description %></p>
          <div class="template-card-footer">
            <div class="template-price-tag">$<%= (p.price / 100).toFixed(0) %></div>
            <% if (p.active) { %>
              <a href="/templates/<%= p.slug %>" class="btn-buy-now">View Details</a>
            <% } else { %>
              <span class="btn-coming-soon-tag">Coming Soon</span>
            <% } %>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
    <div style="text-align:center;margin-top:40px">
      <p style="color:var(--text-mid);font-size:.9rem;margin-bottom:16px">Don&rsquo;t see your industry? I build on request &mdash; you pay once and I add it to the shop.</p>
      <a href="/contact" class="btn btn-gold">Request a Custom Template</a>
    </div>
  </div>
</section>

