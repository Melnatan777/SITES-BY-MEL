<%- include('partials/head', { title: 'Set Up Your Green Cut Website — Sites by Mel', metaDesc: 'Tell us about your lawn care business and upload your photos. Mel will build your personalized website within 24 hours.' }) %>
<%- include('partials/nav', { activePage: 'templates' }) %>

<section style="padding:60px 0 100px;background:#F4F2EE;min-height:80vh">
  <div style="max-width:720px;margin:0 auto;padding:0 24px">

    <div style="text-align:center;margin-bottom:36px">
      <p style="color:#C9922B;font-size:.78rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin-bottom:8px">Green Cut Template</p>
      <h1 style="font-size:1.9rem;font-weight:800;color:#1B2F4E;margin-bottom:10px">Tell Us About Your Lawn Care Business</h1>
      <p style="color:#6B7280;line-height:1.7;max-width:500px;margin:0 auto">Fill in as much as you can. Mel will use everything you provide to build your personalized lawn care website. You'll receive your download link within 24 hours.</p>
    </div>

    <form method="POST" action="/personalize/<%= token %>" enctype="multipart/form-data">

      <div style="max-width:780px;margin:0 auto 0;padding:0 24px;">
        <div style="background:#EFF6FF;border:1px solid #BFDBFE;border-radius:8px;padding:14px 18px;margin:24px 0 8px;font-size:0.88rem;color:#1E40AF;line-height:1.6;">
          <strong>Tip:</strong> Not sure what to write? Check <em>"Let Mel handle this"</em> on any field and she'll craft professional copy that fits your business perfectly. You can also check it on photo slots if you'd like Mel to use a great stock photo instead.
        </div>
      </div>

      <!-- ── SECTION 1: THE BASICS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">1 — The Basics</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Business Name <span style="color:#ef4444">*</span></label>
          <input type="text" name="businessName" placeholder="e.g. Green Valley Lawn Care" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Your Name <span style="color:#ef4444">*</span></label>
            <input type="text" name="ownerName" placeholder="e.g. Jason Miller" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Years in Business</label>
            <input type="text" name="yearsInBusiness" placeholder="e.g. 8" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
            <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Appears as a trust stat on your site</p>
          </div>
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Tagline / Slogan</label>
          <input type="text" name="tagline" placeholder="e.g. Your Lawn, Our Pride" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Leave blank — Mel will write professional copy</p>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Phone Number <span style="color:#ef4444">*</span></label>
            <input type="tel" name="phone" placeholder="(555) 000-0000" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Business Email <span style="color:#ef4444">*</span></label>
            <input type="email" name="email" placeholder="you@yourbusiness.com" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Service Area (Cities / Zip Codes) <span style="color:#ef4444">*</span></label>
          <input type="text" name="serviceArea" placeholder="e.g. Columbus, Westerville, Dublin — 43201, 43081, 43016" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Displayed in your About / Contact sections</p>
        </div>

        <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">City (your base) <span style="color:#ef4444">*</span></label>
            <input type="text" name="city" placeholder="Columbus" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">State</label>
            <input type="text" name="state" placeholder="OH" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Zip</label>
            <input type="text" name="zip" placeholder="43201" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Lawns / Properties Served</label>
            <input type="text" name="propertiesServed" placeholder="e.g. 300+" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
            <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Appears as a trust stat — leave blank to remove</p>
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Instagram Handle</label>
            <input type="text" name="instagram" placeholder="@YourBusiness" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
            <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Optional</p>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Licensed &amp; Insured?</label>
            <select name="licensedInsured" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box;background:#fff">
              <option value="">Select...</option>
              <option value="yes">Yes — licensed &amp; insured</option>
              <option value="no">No</option>
            </select>
            <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">If yes, displays as a trust badge on your site</p>
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Free Estimates?</label>
            <select name="freeEstimates" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box;background:#fff">
              <option value="">Select...</option>
              <option value="yes">Yes — free estimates</option>
              <option value="no">No</option>
            </select>
            <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Displayed prominently in the header/hero area</p>
          </div>
        </div>
      </div>

      <!-- ── SECTION 2: HOURS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">2 — Your Hours</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Monday – Friday</label>
            <input type="text" name="hoursMF" placeholder="7am – 6pm" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Saturday</label>
            <input type="text" name="hoursSat" placeholder="8am – 4pm" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Sunday</label>
            <input type="text" name="hoursSun" placeholder="Closed or by appointment" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>
      </div>

      <!-- ── SECTION 3: SERVICES & PRICING ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">3 — Your Services &amp; Pricing</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <% var services = [
          { num: 1, namePh: 'Lawn Mowing', pricePh: 'Starting at $45', descPh: 'Weekly, bi-weekly, or one-time cuts. We edge, mow, and blow every visit.' },
          { num: 2, namePh: 'Landscaping Design', pricePh: 'Starting at $250', descPh: 'Custom planting plans, mulching, and curb appeal improvements.' },
          { num: 3, namePh: 'Seasonal Cleanup', pricePh: 'Starting at $120', descPh: 'Spring and fall cleanups — leaves, debris, and bed prep.' },
        ]; %>

        <% services.forEach(function(s) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:18px;margin-bottom:14px">
          <p style="font-size:.78rem;font-weight:700;color:#C9922B;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px">Service <%= s.num %></p>
          <div style="display:grid;grid-template-columns:2fr 1fr;gap:12px;margin-bottom:10px">
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Service Name</label>
              <input type="text" name="svc<%= s.num %>Name" placeholder="<%= s.namePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Starting Price</label>
              <input type="text" name="svc<%= s.num %>Price" placeholder="<%= s.pricePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
          </div>
          <div>
            <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Short Description</label>
            <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-bottom:6px;cursor:pointer;">
              <input type="checkbox" name="mel_svc<%= s.num %>_desc" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
              Let Mel handle this
            </label>
            <textarea name="svc<%= s.num %>Desc" rows="2" placeholder="<%= s.descPh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;resize:vertical;box-sizing:border-box"></textarea>
          </div>
        </div>
        <% }); %>
      </div>

      <!-- ── SECTION 4: TESTIMONIALS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">4 — Customer Testimonials</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#f0f4ff;border-radius:8px;padding:12px 16px;margin-bottom:18px;font-size:.82rem;color:#374151;line-height:1.6">
          <strong>No reviews yet?</strong> Leave these blank and Mel will remove the placeholder testimonials from your site.
        </div>

        <% var testimonials = [
          { num: 1, namePh: 'Dave S., Westerville', resultPh: 'Weekly lawn care customer', quotePh: '"My yard looks better than it ever has. They show up on time, every time."', nameField: 'test1Name', resultField: 'test1Result', quoteField: 'test1Quote' },
          { num: 2, namePh: 'Linda P., Dublin', resultPh: 'Spring cleanup + landscaping', quotePh: '"Completely transformed my front yard. Neighbors keep asking who did it."', nameField: 'test2Name', resultField: 'test2Result', quoteField: 'test2Quote' },
          { num: 3, namePh: 'Tom & Karen R.', resultPh: 'Full-season lawn care plan', quotePh: '"Reliable, affordable, and professional. We couldn\'t be happier."', nameField: 'test3Name', resultField: 'test3Result', quoteField: 'test3Quote' },
        ]; %>

        <% testimonials.forEach(function(t) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:18px;margin-bottom:14px">
          <p style="font-size:.78rem;font-weight:700;color:#C9922B;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px">Testimonial <%= t.num %></p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:10px">
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Customer Name</label>
              <input type="text" name="<%= t.nameField %>" placeholder="<%= t.namePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Service Used</label>
              <input type="text" name="<%= t.resultField %>" placeholder="<%= t.resultPh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
          </div>
          <div>
            <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Their Quote</label>
            <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-bottom:6px;cursor:pointer;">
              <input type="checkbox" name="mel_<%= t.quoteField %>" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
              Let Mel handle this
            </label>
            <textarea name="<%= t.quoteField %>" rows="2" placeholder="<%= t.quotePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;resize:vertical;box-sizing:border-box"></textarea>
          </div>
        </div>
        <% }); %>
      </div>

      <!-- ── SECTION 5: CONTACT FORM ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">5 — Contact / Quote Request Form</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#fffdf0;border:1px solid #f0d080;border-radius:8px;padding:12px 16px;margin-bottom:18px;font-size:.82rem;color:#7d5a00;line-height:1.6">
          <strong>Formspree</strong> is free and makes your contact/quote form work. Sign up at <strong>formspree.io</strong>, create a form, and paste the Form ID below (looks like <em>xabcdefg</em>). Leave blank and Mel will add a placeholder.
        </div>

        <div>
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Formspree Form ID</label>
          <input type="text" name="formspreeId" placeholder="xabcdefg" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Just the ID, not the full URL — free at formspree.io</p>
        </div>
      </div>

      <!-- ── SECTION 6: PHOTOS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">6 — Your Photos</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#f0f4ff;border-radius:8px;padding:14px 18px;margin-bottom:22px;font-size:.82rem;color:#374151;line-height:1.7">
          <strong>Photo tips:</strong> JPG or PNG only. Files under 2MB load fastest. Before/after pairs are your strongest selling tool — even phone photos work great.<br>
          <strong>Don't have a photo yet?</strong> Leave any slot blank — Mel will use a styled placeholder you can swap in later.
        </div>

        <% var photos = [
          { field: 'photoHero', label: 'Hero Photo — Beautiful Lawn or Landscaping Job', desc: 'Your proudest work. This is the big image at the top of your home page — make it count.', size: '1600 × 900 px recommended' },
          { field: 'photoBefore', label: 'Before — Overgrown or Messy Lawn', desc: 'Shows the problem you solve. Even a phone photo works great here.', size: '800 × 600 px' },
          { field: 'photoAfter', label: 'After — Same Lawn Cleaned Up', desc: 'The same area after your work. Before/after pairs are your best sales tool.', size: '800 × 600 px' },
          { field: 'photoTeam', label: 'You or Your Team on the Job', desc: 'Puts a face to the business — customers hire people they trust.', size: '800 × 600 px' },
          { field: 'photoEquipment', label: 'Equipment / Truck (Optional)', desc: 'Branded truck or equipment shot — shows you\'re established.', size: '800 × 600 px — optional' },
          { field: 'photoLogo', label: 'Your Logo', desc: 'Used in the header and footer. PNG with transparent background is ideal.', size: 'PNG transparent preferred' },
        ]; %>

        <% photos.forEach(function(p) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:16px 18px;margin-bottom:12px">
          <label style="display:block;font-size:.85rem;font-weight:700;color:#1B2F4E;margin-bottom:4px"><%= p.label %></label>
          <p style="font-size:.78rem;color:#6B7280;margin:0 0 6px;line-height:1.5"><%= p.desc %></p>
          <p style="font-size:.72rem;color:#9CA3AF;margin:0 0 8px">Best size: <strong><%= p.size %></strong></p>
          <input type="file" name="<%= p.field %>" accept="image/jpeg,image/png,image/webp" style="font-size:.82rem;color:#374151">
          <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-top:6px;cursor:pointer;">
            <input type="checkbox" name="mel_stock_<%= p.field %>" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
            Use a professional stock photo instead
          </label>
        </div>
        <% }); %>
      </div>

      <!-- ── SECTION 7: NOTES FOR MEL ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">7 — Anything Else for Mel?</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:28px">
        <textarea name="melNotes" rows="5" placeholder="Additional services, seasonal specials, anything about your service area, sections you want removed, special requests, anything else Mel should know..." style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;resize:vertical;box-sizing:border-box"></textarea>
      </div>

      <button type="submit" style="width:100%;background:#C9922B;color:#fff;border:none;border-radius:10px;padding:18px;font-size:1.05rem;font-weight:700;cursor:pointer">
        Send to Mel →
      </button>

      <p style="text-align:center;font-size:.78rem;color:#9CA3AF;margin-top:12px">You can always email mel@sitesbymel.com with updates or additional photos after submitting.</p>

    </form>
  </div>
</section>

<%- include('partials/footer') %>
