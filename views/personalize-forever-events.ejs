<%- include('partials/head', { title: 'Set Up Your Forever Events Website — Sites by Mel', metaDesc: 'Tell us about your event planning business and upload your photos. We\'ll build your ready-to-launch wedding planner website.' }) %>
<%- include('partials/nav', { activePage: 'templates' }) %>

<section style="padding:60px 0 100px;background:#F4F2EE;min-height:80vh">
  <div style="max-width:720px;margin:0 auto;padding:0 24px">

    <div style="text-align:center;margin-bottom:36px">
      <p style="color:#C9922B;font-size:.78rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin-bottom:8px">Forever Events Template</p>
      <h1 style="font-size:1.9rem;font-weight:800;color:#1B2F4E;margin-bottom:10px">Tell Us About Your Event Planning Business</h1>
      <p style="color:#6B7280;line-height:1.7;max-width:500px;margin:0 auto">Fill in as much as you can. Mel will use everything you provide to build your personalized event planning website. You'll receive your download link within 48 hours.</p>
    </div>

    <form method="POST" action="/personalize/<%= token %>" enctype="multipart/form-data">

      <div style="max-width:780px;margin:0 auto 0;padding:0 24px;">
        <div style="background:#EFF6FF;border:1px solid #BFDBFE;border-radius:8px;padding:14px 18px;margin:24px 0 8px;font-size:0.88rem;color:#1E40AF;line-height:1.6;">
          <strong>Tip:</strong> Not sure what to write? Check <em>"Let Mel handle this"</em> on any field and she'll craft professional copy that fits your business perfectly. You can also check it on photo slots if you'd like Mel to use a great stock photo instead.
        </div>
      </div>

      <!-- ── SECTION 1: THE BASICS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">1 — The Basics</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Business Name <span style="color:#ef4444">*</span></label>
          <input type="text" name="businessName" placeholder="e.g. Bloom & Gather Events" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Your Name <span style="color:#ef4444">*</span></label>
          <input type="text" name="plannerName" placeholder="e.g. Sofia Reyes" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Tagline / Slogan</label>
          <input type="text" name="tagline" placeholder="e.g. Every Detail. Every Dream. Every Moment." style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Leave blank — Mel will write professional copy</p>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Phone Number <span style="color:#ef4444">*</span></label>
            <input type="tel" name="phone" placeholder="(555) 000-0000" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Business Email <span style="color:#ef4444">*</span></label>
            <input type="email" name="email" placeholder="you@youreventco.com" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>

        <div style="display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">City <span style="color:#ef4444">*</span></label>
            <input type="text" name="city" placeholder="Nashville" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">State & Zip</label>
            <input type="text" name="stateZip" placeholder="TN 37201" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Instagram Handle</label>
            <input type="text" name="instagram" placeholder="@BloomAndGather" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Starting Price / Budget Range</label>
            <input type="text" name="startingPrice" placeholder="e.g. Packages starting at $1,500" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Years in Business</label>
            <input type="text" name="yearsExp" placeholder="e.g. 7+" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Events Planned</label>
            <input type="text" name="eventCount" placeholder="e.g. 200+" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Day-of Coordination?</label>
            <select name="dayOfCoord" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box;background:#fff">
              <option value="">Select…</option>
              <option value="yes">Yes</option>
              <option value="no">No</option>
            </select>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:6px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Travel for Destination Events?</label>
            <select name="destinationTravel" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box;background:#fff">
              <option value="">Select…</option>
              <option value="yes">Yes</option>
              <option value="no">No</option>
            </select>
          </div>
        </div>

        <div style="margin-top:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:8px;color:#374151">Types of Events You Plan</label>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
            <label style="display:flex;align-items:center;gap:8px;font-size:.85rem;color:#374151;cursor:pointer">
              <input type="checkbox" name="eventType" value="Weddings"> Weddings
            </label>
            <label style="display:flex;align-items:center;gap:8px;font-size:.85rem;color:#374151;cursor:pointer">
              <input type="checkbox" name="eventType" value="Corporate Events"> Corporate Events
            </label>
            <label style="display:flex;align-items:center;gap:8px;font-size:.85rem;color:#374151;cursor:pointer">
              <input type="checkbox" name="eventType" value="Birthday Parties"> Birthday Parties
            </label>
            <label style="display:flex;align-items:center;gap:8px;font-size:.85rem;color:#374151;cursor:pointer">
              <input type="checkbox" name="eventType" value="Baby Showers"> Baby Showers
            </label>
            <label style="display:flex;align-items:center;gap:8px;font-size:.85rem;color:#374151;cursor:pointer">
              <input type="checkbox" name="eventType" value="Quinceañeras"> Quinceañeras
            </label>
            <label style="display:flex;align-items:center;gap:8px;font-size:.85rem;color:#374151;cursor:pointer">
              <input type="checkbox" name="eventType" value="Other"> Other
            </label>
          </div>
        </div>

      </div>

      <!-- ── SECTION 2: YOUR STORY ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">2 — Your Story (About Page)</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#f0f4ff;border-radius:8px;padding:12px 16px;margin-bottom:18px;font-size:.82rem;color:#374151;line-height:1.6">
          <strong>Tip:</strong> Couples hire planners they connect with emotionally. Share what drew you to this work and what you love about it.
        </div>

        <div>
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Your Bio / Story</label>
          <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-bottom:6px;cursor:pointer;">
            <input type="checkbox" name="mel_bio" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
            Let Mel handle this
          </label>
          <textarea name="bio" rows="6" placeholder="e.g. I planned my sister's wedding on a shoestring budget and realized I had a gift for turning a vision into reality. Seven years and 200+ events later, I still get butterflies watching a couple say 'I do' in a space I helped create..." style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;resize:vertical;box-sizing:border-box"></textarea>
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Leave blank — Mel will write professional copy</p>
        </div>

      </div>

      <!-- ── SECTION 3: PACKAGES ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">3 — Your Packages</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#fffdf0;border:1px solid #f0d080;border-radius:8px;padding:12px 16px;margin-bottom:18px;font-size:.82rem;color:#7d5a00;line-height:1.6">
          Leave any or all blank — Mel will write attractive package descriptions for you.
        </div>

        <% var packages = [
          { num: 1, namePh: 'Day-of Coordination', pricePh: '$800', nameField: 'pkg1Name', priceField: 'pkg1Price', inclField: 'pkg1Included', inclPh: 'e.g.\n- 8 hours of day-of coordination\n- Vendor communication\n- Timeline creation\n- Ceremony & reception management' },
          { num: 2, namePh: 'Partial Planning', pricePh: '$2,200', nameField: 'pkg2Name', priceField: 'pkg2Price', inclField: 'pkg2Included', inclPh: 'e.g.\n- 3 months of planning support\n- Vendor recommendations & booking\n- Budget management\n- Day-of coordination included' },
          { num: 3, namePh: 'Full-Service Planning', pricePh: '$4,500', nameField: 'pkg3Name', priceField: 'pkg3Price', inclField: 'pkg3Included', inclPh: 'e.g.\n- Complete planning from engagement to reception\n- Unlimited consultations\n- All vendor sourcing & management\n- Design, florals, and styling guidance' },
        ]; %>

        <% packages.forEach(function(p) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:18px;margin-bottom:14px">
          <p style="font-size:.78rem;font-weight:700;color:#C9922B;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px">Package <%= p.num %></p>
          <div style="display:grid;grid-template-columns:2fr 1fr;gap:12px;margin-bottom:10px">
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Package Name</label>
              <input type="text" name="<%= p.nameField %>" placeholder="<%= p.namePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Price / Starting Price</label>
              <input type="text" name="<%= p.priceField %>" placeholder="<%= p.pricePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
          </div>
          <div>
            <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">What's Included (3–4 bullet points)</label>
            <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-bottom:6px;cursor:pointer;">
              <input type="checkbox" name="mel_<%= p.inclField %>" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
              Let Mel handle this
            </label>
            <textarea name="<%= p.inclField %>" rows="4" placeholder="<%= p.inclPh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;resize:vertical;box-sizing:border-box"></textarea>
          </div>
        </div>
        <% }); %>

      </div>

      <!-- ── SECTION 4: TESTIMONIALS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">4 — Client Testimonials</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#f0f4ff;border-radius:8px;padding:12px 16px;margin-bottom:18px;font-size:.82rem;color:#374151;line-height:1.6">
          <strong>No reviews yet?</strong> Leave these blank and Mel will remove the placeholder testimonials from your site.
        </div>

        <% var testimonials = [
          { num: 1, namePh: 'Emma & James T.', eventPh: 'Wedding — June 2024', quotePh: '"Sofia turned our vision into something even more beautiful than we imagined..."', nameField: 'test1Name', eventField: 'test1Event', quoteField: 'test1Quote' },
          { num: 2, namePh: 'The Rodriguez Family', eventPh: 'Quinceañera — March 2024', quotePh: '"Every detail was perfect. Our guests are still talking about it..."', nameField: 'test2Name', eventField: 'test2Event', quoteField: 'test2Quote' },
          { num: 3, namePh: 'Sarah M.', eventPh: 'Corporate Gala — November 2023', quotePh: '"Professional, creative, and stress-free from start to finish..."', nameField: 'test3Name', eventField: 'test3Event', quoteField: 'test3Quote' },
        ]; %>

        <% testimonials.forEach(function(t) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:18px;margin-bottom:14px">
          <p style="font-size:.78rem;font-weight:700;color:#C9922B;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px">Testimonial <%= t.num %></p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:10px">
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Couple / Client Name</label>
              <input type="text" name="<%= t.nameField %>" placeholder="<%= t.namePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Event Type + Date</label>
              <input type="text" name="<%= t.eventField %>" placeholder="<%= t.eventPh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
          </div>
          <div>
            <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Their Quote</label>
            <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-bottom:6px;cursor:pointer;">
              <input type="checkbox" name="mel_<%= t.quoteField %>" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
              Let Mel handle this
            </label>
            <textarea name="<%= t.quoteField %>" rows="2" placeholder="<%= t.quotePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;resize:vertical;box-sizing:border-box"></textarea>
          </div>
        </div>
        <% }); %>

      </div>

      <!-- ── SECTION 5: CONTACT FORM ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">5 — Contact Form</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#EEF4FF;border:1px solid #C7D7FC;border-radius:8px;padding:16px 20px;font-size:.85rem;color:#374151;line-height:1.6">
          <strong style="color:#1B2F4E;display:block;margin-bottom:6px">✅ Contact form already included</strong>
          Your website has a built-in contact form — visitors can send you a message directly from the site.
          Mel will activate it for you when delivering your completed site. No extra setup needed on your end.
        </div>

      </div>

      <!-- ── SECTION 6: PHOTOS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">6 — Your Photos</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#f0f4ff;border-radius:8px;padding:14px 18px;margin-bottom:22px;font-size:.82rem;color:#374151;line-height:1.7">
          <strong>Photo tips:</strong> JPG or PNG only. Files under 2MB load fastest. Beautiful event photography is the #1 selling point for planners — use your best shots!<br>
          <strong>Don't have photos yet?</strong> Leave any slot blank — Mel will use a styled placeholder and you can swap it in later.
        </div>

        <% var photos = [
          { field: 'photoHero', label: 'Hero Photo — Your Best Wedding or Event Setup', desc: 'The stunning banner image at the top of your site. Choose your most jaw-dropping event photo.', size: '1600×900 landscape' },
          { field: 'photoCeremony', label: 'Wedding Ceremony Photo', desc: 'A beautiful ceremony moment — altar, aisle, or vow exchange.', size: '800×600 landscape' },
          { field: 'photoReception', label: 'Reception / Decor Detail', desc: 'A reception setup, table arrangement, or stunning decor detail.', size: '800×600 landscape' },
          { field: 'photoPortrait', label: 'Your Portrait / You at Work', desc: 'A photo of you — working an event, consulting with clients, or a professional headshot.', size: '800×800 square or portrait' },
          { field: 'photoEvent2', label: 'Another Beautiful Event You Planned', desc: 'A second highlight event — could be a corporate, birthday, or another wedding.', size: '800×600 landscape' },
          { field: 'photoFloral', label: 'Floral / Tablescape Detail', desc: 'A close-up beauty shot — flowers, centerpiece, table setting, or decor detail.', size: '800×600 landscape' },
          { field: 'photoLogo', label: 'Logo (PNG transparent preferred)', desc: 'Your business logo. PNG with transparent background is ideal.', size: 'PNG transparent preferred' },
        ]; %>

        <% photos.forEach(function(p) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:16px 18px;margin-bottom:12px">
          <label style="display:block;font-size:.85rem;font-weight:700;color:#1B2F4E;margin-bottom:4px"><%= p.label %></label>
          <p style="font-size:.78rem;color:#6B7280;margin:0 0 8px;line-height:1.5"><%= p.desc %></p>
          <p style="font-size:.72rem;color:#9CA3AF;margin:0 0 8px">Best size: <strong><%= p.size %></strong></p>
          <input type="file" name="<%= p.field %>" accept="image/jpeg,image/png,image/webp" style="font-size:.82rem;color:#374151">
          <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-top:6px;cursor:pointer;">
            <input type="checkbox" name="mel_stock_<%= p.field %>" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
            Use a professional stock photo instead
          </label>
        </div>
        <% }); %>

      </div>

      <!-- ── SECTION 7: NOTES FOR MEL ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">7 — Anything Else for Mel?</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:28px">
        <textarea name="melNotes" rows="4" placeholder="Any special requests, sections you want removed, extra info Mel should know... (Awards, featured publications like 'The Knot Best of Weddings', preferred vendor relationships, or anything that makes you stand out — add it here!)" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;resize:vertical;box-sizing:border-box"></textarea>
      </div>

      <div style="background:#fefce8;border:1px solid #fde68a;border-radius:8px;padding:14px 16px;margin-bottom:12px;display:flex;align-items:flex-start;gap:10px"><input type="checkbox" name="agreed_to_terms" value="yes" required style="margin-top:3px;width:16px;height:16px;flex-shrink:0;accent-color:#C9922B;cursor:pointer"><label style="font-size:.82rem;color:#374151;line-height:1.6;cursor:pointer">I have read and agree to the <a href="/agreement" target="_blank" style="color:#C9922B;font-weight:700;text-decoration:underline">Sites by Mel Website Design Agreement</a> and understand that custom website work begins after submission.</label></div>
      <button type="submit" style="width:100%;background:#C9922B;color:#fff;border:none;border-radius:10px;padding:18px;font-size:1.05rem;font-weight:700;cursor:pointer">
        Send to Mel →
      </button>

      <p style="text-align:center;font-size:.78rem;color:#9CA3AF;margin-top:12px">You can always email mel@sitesbymel.com with updates or additional photos after submitting.</p>

    </form>
  </div>
</section>

<%- include('partials/footer') %>
