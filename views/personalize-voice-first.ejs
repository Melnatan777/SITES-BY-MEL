<%- include('partials/head', { title: 'Set Up Your Voice First Website — Sites by Mel', metaDesc: 'Tell us about your podcast, voice-over, or speaking business and upload your photos. We\'ll build your ready-to-launch website.' }) %>
<%- include('partials/nav', { activePage: 'templates' }) %>

<section style="padding:60px 0 100px;background:#F4F2EE;min-height:80vh">
  <div style="max-width:720px;margin:0 auto;padding:0 24px">

    <div style="text-align:center;margin-bottom:36px">
      <p style="color:#C9922B;font-size:.78rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin-bottom:8px">Voice First Template</p>
      <h1 style="font-size:1.9rem;font-weight:800;color:#1B2F4E;margin-bottom:10px">Tell Us About Your Show & Brand</h1>
      <p style="color:#6B7280;line-height:1.7;max-width:500px;margin:0 auto">Fill in as much as you can. Mel will use everything you provide to build your personalized website. You'll receive your download link within 48 hours.</p>
    </div>

    <form method="POST" action="/personalize/<%= token %>" enctype="multipart/form-data">

      <div style="max-width:780px;margin:0 auto 0;padding:0 24px;">
        <div style="background:#EFF6FF;border:1px solid #BFDBFE;border-radius:8px;padding:14px 18px;margin:24px 0 8px;font-size:0.88rem;color:#1E40AF;line-height:1.6;">
          <strong>Tip:</strong> Not sure what to write? Check <em>"Let Mel handle this"</em> on any field and she'll craft professional copy that fits your business perfectly. You can also check it on photo slots if you'd like Mel to use a great stock photo instead.
        </div>
      </div>

      <!-- ── SECTION 1: THE BASICS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">1 — The Basics</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Business / Brand Name <span style="color:#ef4444">*</span></label>
          <input type="text" name="businessName" placeholder="e.g. Jordan Speaks Media" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Show / Channel Name</label>
          <input type="text" name="showName" placeholder="Leave blank if same as Business Name" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Only fill in if your show has a different name from your brand, e.g. "The Bold Move Podcast"</p>
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Your Name <span style="color:#ef4444">*</span></label>
          <input type="text" name="yourName" placeholder="e.g. Jordan Mills" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Tagline / Slogan</label>
          <input type="text" name="tagline" placeholder="e.g. Real Stories. Bold Conversations." style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Leave blank — Mel will write professional copy</p>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Phone Number</label>
            <input type="tel" name="phone" placeholder="(555) 000-0000" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
            <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Leave blank if you prefer email-only contact</p>
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Business Email <span style="color:#ef4444">*</span></label>
            <input type="email" name="email" placeholder="you@yourbrand.com" required style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">City / State</label>
            <input type="text" name="cityState" placeholder="e.g. Austin, TX" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
            <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Leave blank if you prefer not to list a location</p>
          </div>
          <div>
            <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Episode Count (stat)</label>
            <input type="text" name="episodeCount" placeholder="e.g. 100+ episodes" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          </div>
        </div>
      </div>

      <!-- ── SECTION 2: SHOW DETAILS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">2 — Show Details</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="margin-bottom:20px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:8px;color:#374151">Platform(s)</label>
          <div style="display:flex;gap:16px;flex-wrap:wrap">
            <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
              <input type="checkbox" name="platformSpotify" value="yes"> Spotify
            </label>
            <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
              <input type="checkbox" name="platformApple" value="yes"> Apple Podcasts
            </label>
            <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
              <input type="checkbox" name="platformYouTube" value="yes"> YouTube
            </label>
            <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
              <input type="checkbox" name="platformAmazon" value="yes"> Amazon Music
            </label>
            <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
              <input type="checkbox" name="platformIheart" value="yes"> iHeart
            </label>
            <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
              <input type="checkbox" name="platformOther" value="yes"> Other
            </label>
          </div>
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:8px;color:#374151">Guest or Solo Show?</label>
          <div style="display:flex;gap:20px;flex-wrap:wrap">
            <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
              <input type="radio" name="showFormat" value="solo"> Solo Host
            </label>
            <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
              <input type="radio" name="showFormat" value="interview"> Interview-Style
            </label>
            <label style="display:flex;align-items:center;gap:7px;font-size:.88rem;color:#374151;cursor:pointer">
              <input type="radio" name="showFormat" value="both"> Both
            </label>
          </div>
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Topics / Categories Covered</label>
          <input type="text" name="topics" placeholder="e.g. entrepreneurship, marketing, mindset, personal finance" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Leave blank — Mel will write professional copy</p>
        </div>

        <div style="margin-bottom:18px">
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Booking Link for Speaking / Guest Appearances</label>
          <input type="url" name="bookingLink" placeholder="e.g. calendly.com/yourname/podcast-guest (optional)" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Used for your CTA button. Leave blank to skip.</p>
        </div>

        <div>
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Spotify / Apple Podcasts Embed Link</label>
          <input type="url" name="embedLink" placeholder="e.g. open.spotify.com/show/... (optional)" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;box-sizing:border-box">
          <p style="font-size:.72rem;color:#9CA3AF;margin-top:3px">Used for the episode player on your site. Leave blank to skip.</p>
        </div>
      </div>

      <!-- ── SECTION 3: YOUR STORY ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">3 — Your Story (About Page)</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#f0f4ff;border-radius:8px;padding:12px 16px;margin-bottom:18px;font-size:.82rem;color:#374151;line-height:1.6">
          <strong>Tip:</strong> Write in first person. Your voice and personality are your brand — let people hear who you are before they press play.
        </div>

        <div>
          <label style="display:block;font-size:.82rem;font-weight:700;margin-bottom:5px;color:#374151">Your Bio / Story</label>
          <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-bottom:6px;cursor:pointer;">
            <input type="checkbox" name="mel_bio" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
            Let Mel handle this
          </label>
          <textarea name="bio" rows="6" placeholder="Leave blank — Mel will write professional copy for you" style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;resize:vertical;box-sizing:border-box"></textarea>
        </div>
      </div>

      <!-- ── SECTION 4: FEATURED EPISODES ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">4 — Featured Episodes</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#f0f4ff;border-radius:8px;padding:12px 16px;margin-bottom:18px;font-size:.82rem;color:#374151;line-height:1.6">
          Leave blank — Mel will use placeholder episode titles.
        </div>

        <% var episodes = [
          { num: 1, titleField: 'ep1Title', epNumField: 'ep1Num', descField: 'ep1Desc' },
          { num: 2, titleField: 'ep2Title', epNumField: 'ep2Num', descField: 'ep2Desc' },
          { num: 3, titleField: 'ep3Title', epNumField: 'ep3Num', descField: 'ep3Desc' },
        ]; %>

        <% episodes.forEach(function(e) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:18px;margin-bottom:14px">
          <p style="font-size:.78rem;font-weight:700;color:#C9922B;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px">Featured Episode <%= e.num %></p>
          <div style="display:grid;grid-template-columns:2fr 1fr;gap:12px;margin-bottom:10px">
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Episode Title</label>
              <input type="text" name="<%= e.titleField %>" placeholder="e.g. How to Land Your First Client with Zero Experience" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Episode # or Date</label>
              <input type="text" name="<%= e.epNumField %>" placeholder="e.g. Ep. 47 or Jan 2025" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
          </div>
          <div>
            <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">1-Line Description</label>
            <input type="text" name="<%= e.descField %>" placeholder="e.g. The exact cold-outreach script that got me my first 3 paying clients" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
          </div>
        </div>
        <% }); %>

      </div>

      <!-- ── SECTION 5: SERVICES / OFFERINGS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">5 — Services / Offerings</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <% var services = [
          { num: 1, namePh: 'Podcast Editing', pricePh: 'Starting at $150/ep', nameField: 'svc1Name', priceField: 'svc1Price', descField: 'svc1Desc', descPh: 'Full audio cleanup, noise reduction, intro/outro, and chapter markers...' },
          { num: 2, namePh: 'Voice-Over Work', pricePh: 'Contact for quote', nameField: 'svc2Name', priceField: 'svc2Price', descField: 'svc2Desc', descPh: 'Professional voice-over for ads, explainer videos, audiobooks, and more...' },
          { num: 3, namePh: 'Speaking Engagements', pricePh: 'Contact for booking', nameField: 'svc3Name', priceField: 'svc3Price', descField: 'svc3Desc', descPh: 'Available for keynotes, panels, workshops, and corporate events...' },
        ]; %>

        <% services.forEach(function(s) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:18px;margin-bottom:14px">
          <p style="font-size:.78rem;font-weight:700;color:#C9922B;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px">Offering <%= s.num %></p>
          <div style="display:grid;grid-template-columns:2fr 1fr;gap:12px;margin-bottom:10px">
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Service / Offering Name</label>
              <input type="text" name="<%= s.nameField %>" placeholder="<%= s.namePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Price</label>
              <input type="text" name="<%= s.priceField %>" placeholder="<%= s.pricePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
          </div>
          <div>
            <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Short Description</label>
            <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-bottom:6px;cursor:pointer;">
              <input type="checkbox" name="mel_<%= s.descField %>" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
              Let Mel handle this
            </label>
            <textarea name="<%= s.descField %>" rows="2" placeholder="<%= s.descPh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;resize:vertical;box-sizing:border-box"></textarea>
          </div>
        </div>
        <% }); %>

      </div>

      <!-- ── SECTION 6: TESTIMONIALS / REVIEWS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">6 — Listener Reviews / Testimonials</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#f0f4ff;border-radius:8px;padding:12px 16px;margin-bottom:18px;font-size:.82rem;color:#374151;line-height:1.6">
          <strong>No reviews yet?</strong> Leave these blank and Mel will remove the placeholder testimonials from your site.
        </div>

        <% var testimonials = [
          { num: 1, namePh: 'Alex R.', resultPh: 'Apple Podcasts', quotePh: '"5 stars. Every episode is packed with value and the host keeps things real. This is the only podcast I never skip..."', nameField: 'test1Name', resultField: 'test1Platform', quoteField: 'test1Quote' },
          { num: 2, namePh: 'Morgan T.', resultPh: 'Spotify', quotePh: '"I\'ve been listening since episode 1 and the quality just keeps getting better. Highly recommend to anyone in the space..."', nameField: 'test2Name', resultField: 'test2Platform', quoteField: 'test2Quote' },
        ]; %>

        <% testimonials.forEach(function(t) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:18px;margin-bottom:14px">
          <p style="font-size:.78rem;font-weight:700;color:#C9922B;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px">Review <%= t.num %></p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:10px">
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Reviewer Name</label>
              <input type="text" name="<%= t.nameField %>" placeholder="<%= t.namePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
            <div>
              <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Platform</label>
              <input type="text" name="<%= t.resultField %>" placeholder="<%= t.resultPh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;box-sizing:border-box">
            </div>
          </div>
          <div>
            <label style="display:block;font-size:.78rem;font-weight:700;margin-bottom:4px;color:#374151">Their Review Quote</label>
            <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-bottom:6px;cursor:pointer;">
              <input type="checkbox" name="mel_<%= t.quoteField %>" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
              Let Mel handle this
            </label>
            <textarea name="<%= t.quoteField %>" rows="2" placeholder="<%= t.quotePh %>" style="width:100%;padding:9px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:.88rem;resize:vertical;box-sizing:border-box"></textarea>
          </div>
        </div>
        <% }); %>

      </div>

      <!-- ── SECTION 7: CONTACT FORM ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">7 — Contact Form</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

      </div>

      <!-- ── SECTION 8: PHOTOS ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">8 — Your Photos</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:20px">

        <div style="background:#f0f4ff;border-radius:8px;padding:14px 18px;margin-bottom:22px;font-size:.82rem;color:#374151;line-height:1.7">
          <strong>Photo tips:</strong> JPG or PNG only. Landscape photos (wider than tall) work best for banners. Your headshot is especially important for this template — it appears prominently across the site. Files under 2MB load fastest.<br>
          <strong>Don't have photos yet?</strong> Leave any slot blank — Mel will leave a styled placeholder and you can swap it in later.
        </div>

        <% var photos = [
          { field: 'photoHero', label: 'Hero Photo — You at Your Mic / In Your Studio', desc: 'The big image at the top of your home page. You at your microphone, in your recording space, or in a creative environment.', size: '1600×900 (landscape)' },
          { field: 'photoHeadshot', label: 'Your Portrait / Headshot', desc: 'Your main professional headshot. Very important for this template — used prominently throughout the site to build your personal brand.', size: '800×800 (square)' },
          { field: 'photoStudio', label: 'Recording Setup / Studio Photo', desc: 'A photo of your recording setup, microphone, or studio space.', size: '800×600 (landscape)' },
          { field: 'photoSpeaking', label: 'You Speaking or Presenting (optional)', desc: 'A photo of you on a stage, at an event, or presenting. Leave blank to skip.', size: '800×600 (landscape)' },
          { field: 'photoLogo', label: 'Logo or Podcast Cover Art', desc: 'Your logo or podcast cover art. Square PNG preferred — this is what listeners see on Spotify, Apple Podcasts, etc.', size: '1400×1400 (square PNG preferred)' },
        ]; %>

        <% photos.forEach(function(p) { %>
        <div style="border:1px solid #E5E0D8;border-radius:8px;padding:16px 18px;margin-bottom:12px">
          <label style="display:block;font-size:.85rem;font-weight:700;color:#1B2F4E;margin-bottom:4px"><%= p.label %></label>
          <p style="font-size:.78rem;color:#6B7280;margin:0 0 8px;line-height:1.5"><%= p.desc %></p>
          <p style="font-size:.72rem;color:#9CA3AF;margin:0 0 8px">Best size: <strong><%= p.size %></strong></p>
          <input type="file" name="<%= p.field %>" accept="image/jpeg,image/png,image/webp" style="font-size:.82rem;color:#374151">
          <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:#6B7280;margin-top:6px;cursor:pointer;">
            <input type="checkbox" name="mel_stock_<%= p.field %>" value="yes" style="width:14px;height:14px;accent-color:#1d4ed8;cursor:pointer;">
            Use a professional stock photo instead
          </label>
        </div>
        <% }); %>

      </div>

      <!-- ── SECTION 9: NOTES FOR MEL ── -->
      <div style="background:#1B2F4E;border-radius:12px 12px 0 0;padding:14px 24px">
        <h2 style="color:#fff;font-size:.95rem;font-weight:700;margin:0">9 — Anything Else for Mel?</h2>
      </div>
      <div style="background:#fff;border:1px solid #E5E0D8;border-top:none;border-radius:0 0 12px 12px;padding:28px;margin-bottom:28px">
        <textarea name="melNotes" rows="4" placeholder="Any special requests, sections you want removed, extra info Mel should know..." style="width:100%;padding:10px 14px;border:1px solid #D1D5DB;border-radius:6px;font-size:.9rem;resize:vertical;box-sizing:border-box"></textarea>
      </div>

      <div style="background:#fefce8;border:1px solid #fde68a;border-radius:8px;padding:14px 16px;margin-bottom:12px;display:flex;align-items:flex-start;gap:10px"><input type="checkbox" name="agreed_to_terms" value="yes" required style="margin-top:3px;width:16px;height:16px;flex-shrink:0;accent-color:#C9922B;cursor:pointer"><label style="font-size:.82rem;color:#374151;line-height:1.6;cursor:pointer">I have read and agree to the <a href="/agreement" target="_blank" style="color:#C9922B;font-weight:700;text-decoration:underline">Sites by Mel Website Design Agreement</a> and understand that custom website work begins after submission.</label></div>
      <button type="submit" style="width:100%;background:#C9922B;color:#fff;border:none;border-radius:10px;padding:18px;font-size:1.05rem;font-weight:700;cursor:pointer">
        Send to Mel →
      </button>

      <p style="text-align:center;font-size:.78rem;color:#9CA3AF;margin-top:12px">You can always email mel@sitesbymel.com with updates or additional photos after submitting.</p>

    </form>
  </div>
</section>

