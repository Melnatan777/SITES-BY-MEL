<%- include('partials/head', { title: post.title + ' — Sites by Mel Blog', metaDesc: post.excerpt }) %>
<%- include('partials/nav', { activePage: 'blog' }) %>

<div class="page-header" style="text-align:left;padding:36px 24px;">
  <div class="container">
    <p style="font-size:0.85rem;opacity:0.65;margin-bottom:8px;"><a href="/blog" style="color:rgba(255,255,255,0.7);">Blog</a> &rsaquo; <%= post.category %></p>
    <h1 style="margin-bottom:0;max-width:720px;line-height:1.3"><%= post.title %></h1>
    <p style="margin-top:12px;opacity:.7;font-size:.87rem"><%= post.date %> &bull; <%= post.read %> read</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 320px;gap:48px;align-items:start" class="blog-post-grid">

      <!-- ARTICLE BODY -->
      <article>
        <p style="font-size:1.08rem;color:var(--gray);line-height:1.85;font-style:italic;border-left:4px solid var(--gold);padding-left:18px;margin-bottom:32px"><%= post.excerpt %></p>
        <div class="blog-body" style="color:#374151;line-height:1.85;font-size:.97rem">
          <%- post.body %>
        </div>

        <!-- BACK + SUBSCRIBE -->
        <div style="margin-top:48px;padding-top:32px;border-top:1px solid var(--border)">
          <a href="/blog" style="font-size:.85rem;color:var(--gold);font-weight:700;text-decoration:none">&larr; Back to All Articles</a>
        </div>
      </article>

      <!-- SIDEBAR -->
      <aside>
        <!-- Subscribe -->
        <div style="background:var(--navy);border-radius:12px;padding:28px;margin-bottom:24px;text-align:center">
          <h3 style="color:#fff;font-size:1rem;margin-bottom:8px">Get Weekly Tips</h3>
          <p style="color:rgba(255,255,255,.7);font-size:.82rem;line-height:1.6;margin-bottom:18px">Practical small business advice delivered every Monday.</p>
          <form onsubmit="subscribeSide(event)" style="display:flex;flex-direction:column;gap:8px">
            <input type="email" id="side-email" placeholder="your@email.com" required style="padding:10px 14px;border:none;border-radius:6px;font-size:.88rem">
            <button type="submit" style="background:var(--gold);color:#fff;border:none;border-radius:6px;padding:10px;font-weight:700;font-size:.88rem;cursor:pointer">Subscribe</button>
          </form>
          <p id="side-msg" style="color:rgba(255,255,255,.8);font-size:.78rem;margin-top:8px;min-height:16px"></p>
        </div>

        <!-- More articles -->
        <div style="background:#fff;border:1px solid var(--border);border-radius:12px;padding:24px">
          <h3 style="font-size:.9rem;font-weight:700;color:var(--navy);margin-bottom:16px">More Articles</h3>
          <% others.forEach(function(p) { %>
          <div style="padding-bottom:14px;margin-bottom:14px;border-bottom:1px solid var(--border)">
            <span style="font-size:.7rem;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.06em"><%= p.category %></span>
            <a href="/blog/<%= p.slug %>" style="display:block;font-size:.85rem;font-weight:600;color:var(--navy);text-decoration:none;line-height:1.4;margin-top:4px"><%= p.title %></a>
          </div>
          <% }); %>
          <a href="/blog" style="font-size:.82rem;font-weight:700;color:var(--gold);text-decoration:none">View all articles &rarr;</a>
        </div>

        <!-- CTA -->
        <div style="background:#fdf6e3;border:1px solid #f0d080;border-radius:12px;padding:24px;margin-top:24px;text-align:center">
          <p style="font-size:.88rem;font-weight:700;color:var(--navy);margin-bottom:8px">Ready for your own website?</p>
          <p style="font-size:.8rem;color:var(--gray);line-height:1.6;margin-bottom:14px">Templates start at $197. Professional setup available.</p>
          <a href="/templates" class="btn btn-gold btn-sm btn-full">Browse Templates</a>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
async function subscribeSide(e) {
  e.preventDefault();
  const email = document.getElementById('side-email').value;
  const msg = document.getElementById('side-msg');
  try {
    const res = await fetch('/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email })
    });
    const data = await res.json();
    msg.textContent = data.message;
    if (data.ok) document.getElementById('side-email').value = '';
  } catch(err) {
    msg.textContent = 'Try again.';
  }
}
</script>

<style>
.blog-body h3 { font-size: 1.1rem; font-weight: 700; color: var(--navy); margin: 28px 0 12px; }
.blog-body p { margin-bottom: 18px; }
@media (max-width: 800px) {
  .blog-post-grid { grid-template-columns: 1fr !important; }
  aside { order: -1; }
}
</style>

<%- include('partials/footer') %>
